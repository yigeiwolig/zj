<!-- pages/pagenew/pagenew.wxml -->
<view class="container">

<!-- ================= 1. 自定义导航栏 ================= -->
<view class="header" style="padding-top: {{statusBarHeight}}px;">
  <view class="back-icon" catchtap="goBack" style="top: {{statusBarHeight + 10}}px;">
    <text class="back-arrow">‹</text>
  </view>
</view>
<view class="nav-header" style="padding-top: {{statusBarHeight}}px; height: {{statusBarHeight + navBarHeight + 20}}px;">
  <view class="brand-title" style="top: {{statusBarHeight + navBarHeight / 2}}px;">
    <text>MT 新品展示</text>
    <view wx:if="{{isAuthorized}}" class="admin-toggle-btn {{isAdmin ? 'on' : ''}}" catchtap="toggleAdminMode">
      {{isAdmin ? 'EXIT' : 'EDIT'}}
    </view>
  </view>
</view>

<!-- ================= 2. 核心滑动区 ================= -->
<view class="swiper-container">
  <swiper 
    class="card-swiper" 
    current="{{currentIndex}}" 
    previous-margin="50rpx" 
    next-margin="50rpx" 
    bindchange="onSwiperChange"
    circular="{{false}}"
  >
    <block wx:for="{{products}}" wx:key="_id">
      <swiper-item class="card-wrapper">
        
        <!-- ⚠️ 关键修改：非管理员模式下点击卡片可跳转，管理员模式下不跳转 -->
        <view class="apple-card {{currentIndex === index ? 'active' : ''}}" bindtap="{{!isAdmin ? 'handleCardClick' : ''}}" data-index="{{index}}">
          
          <!-- A. 图片区域 -->
          <view class="card-cover">
            <view class="product-cover-wrapper">
              <image class="cover-img" src="{{item.cover || defaultCover}}" mode="aspectFill" lazy-load/>
              <!-- 跳转号码标识（管理员模式下可编辑） -->
              <view wx:if="{{isAdmin}}" class="jump-number-badge" catchtap="handleEditJumpNumber" data-index="{{index}}">
                <text wx:if="{{item.jumpNumber}}">#{{item.jumpNumber}}</text>
                <text wx:else>#</text>
              </view>
            </view>
            
            <!-- [管理员] 功能区 (只有管理员能点) -->
            <block wx:if="{{isAdmin}}">
              <!-- 左上角：删除 -->
              <view class="admin-btn btn-del" catchtap="handleDeleteProduct">✕</view>
              <!-- 右上角：换封面 -->
              <view class="admin-btn btn-cam" catchtap="handleUploadCover">📷</view>
            </block>
          </view>

          <!-- B. 信息区域 -->
          <view class="card-content">
            <view class="info-text">
              <!-- 标题 (管理员点击可修) -->
              <text 
                class="p-title {{isAdmin ? 'editable' : ''}}" 
                catchtap="{{isAdmin ? 'handleEditTitle' : ''}}"
              >{{item.title || 'New Product'}}</text>

              <!-- 价格 (管理员点击可修) -->
              <text 
                class="p-price {{isAdmin ? 'editable' : ''}}" 
                catchtap="{{isAdmin ? 'handleEditPrice' : ''}}"
              >¥ {{item.price || '0'}}</text>
            </view>

            <!-- 装饰用的箭头按钮 (纯装饰，无点击事件) -->
            <view class="btn-go" wx:if="{{!isAdmin}}">
              <view class="icon-arrow"></view>
            </view>
            
            <!-- 管理员可见的设置图标 (装饰) -->
            <view class="btn-go admin-icon" wx:if="{{isAdmin}}">⚙️</view>
          </view>

        </view>
      </swiper-item>
    </block>

    <!-- [管理员] 新建卡片 -->
    <swiper-item class="card-wrapper" wx:if="{{isAdmin}}">
      <view class="apple-card add-card {{currentIndex === products.length ? 'active' : ''}}" bindtap="handleAddNew">
        <view class="add-icon">+</view>
        <text class="add-text">NEW ARRIVAL</text>
      </view>
    </swiper-item>

  </swiper>
</view>


</view>

<!-- ================= 自定义编辑弹窗 ================= -->
<view class="custom-modal-mask {{customEditModalClosing ? 'closing' : ''}}" wx:if="{{showCustomEditModal}}" bindtap="closeCustomEditModal" catchtouchmove="noop" catchtap="noop">
  <view class="custom-modal-box" catchtap="noop" catchtouchmove="noop">
    <view class="modal-title">{{customEditTitle}}</view>
    <input 
      class="modal-input" 
      type="text" 
      placeholder="请输入号码"
      value="{{customEditVal}}"
      bindinput="onCustomEditInput"
      confirm-type="done"
      bindconfirm="confirmCustomEdit"
      focus="{{showCustomEditModal}}"
    />
    <view class="modal-btn-row">
      <view class="modal-btn cancel" bindtap="closeCustomEditModal">取消</view>
      <view class="modal-btn confirm" bindtap="confirmCustomEdit">确定</view>
    </view>
  </view>
</view>

<!-- 全局自定义弹窗组件 -->
<custom-toast id="custom-toast" />
