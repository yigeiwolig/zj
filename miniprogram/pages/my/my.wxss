/* 1. 品牌头部 */
.logistics-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 48rpx 32rpx; /* 增加留白 */
  background: #fff;
  z-index: 10;
  position: relative;
}

.logistics-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 48rpx;
  right: 48rpx;
  height: 1rpx;
  background: rgba(0,0,0,0.05); /* 极细的分隔线 */
}

.brand-tag {
  font-size: 32rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #8E8E93;
  background: rgba(142, 142, 147, 0.12); /* 苹果风格的灰色背景 */
  border-radius: 50%;
  transition: all 0.2s;
}
.close-btn:active {
  background: rgba(142, 142, 147, 0.24);
  transform: scale(0.92);
}

.logistics-modal-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  min-height: 0;
  /* 🔴 关键修复：确保 flex 子元素可以正确计算高度 */
  height: 0; /* 在 flex 布局中，设置为 0 让 flex: 1 生效 */
  background: #F5F5F7; /* 整体背景改为浅灰，突出卡片 */
  /* 🔴 确保内容区域可以滚动 */
  flex-shrink: 1;
}

/* 2. 核心信息区 */
.logistics-card-container {
  padding: 32rpx 32rpx 0;
  background: #F5F5F7;
  z-index: 5;
  flex-shrink: 0;
}

.logistics-info-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx; /* 减小内边距 40rpx -> 32rpx */
  position: relative;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx; /* 减小间距 32rpx -> 24rpx */
}

.company-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.company-icon-placeholder {
  width: 64rpx; /* 减小图标 72rpx -> 64rpx */
  height: 64rpx;
  background: #007AFF;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(0, 122, 255, 0.25);
}

.company-name {
  font-size: 30rpx; /* 减小字号 34rpx -> 30rpx */
  color: #1D1D1F;
  font-weight: 600;
}

.status-badge {
  font-size: 22rpx; /* 减小字号 24rpx -> 22rpx */
  color: #fff;
  background: #007AFF;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 122, 255, 0.2);
}

.status-badge.success {
  background: #34C759;
  box-shadow: 0 4rpx 10rpx rgba(52, 199, 89, 0.2);
}

.card-body-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F5F7FA;
  padding: 20rpx 24rpx; /* 减小内边距 */
  border-radius: 20rpx;
}

.tracking-number {
  font-family: 'DIN Alternate', 'Helvetica Neue', sans-serif;
  font-size: 32rpx; /* 减小字号 36rpx -> 32rpx */
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 1rpx;
}

.copy-btn {
  font-size: 22rpx; /* 减小字号 24rpx -> 22rpx */
  color: #1D1D1F;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.copy-btn:active {
  background: #f2f2f2;
  transform: scale(0.95);
}

/* 3. 加载状态 */
.logistics-loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}
.mt-loader {
  width: 50rpx;
  height: 50rpx;
  border: 5rpx solid rgba(0, 122, 255, 0.1);
  border-top: 5rpx solid #007AFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 4. 错误提示 */
.logistics-error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.error-text {
  font-size: 28rpx;
  color: #8E8E93;
}

/* 5. 物流轨迹列表 (高级时间轴) */
.logistics-scroll {
  flex: 1;
  /* 🔴 关键修复：scroll-view 需要明确的高度才能滚动 */
  height: 0; /* 在 flex 布局中，设置为 0 让 flex: 1 生效 */
  min-height: 0; /* 允许收缩 */
  padding: 20rpx 32rpx 0;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
  /* 🔴 确保可以滚动 */
  overflow-y: auto;
  /* 🔴 关键：确保 scroll-view 可以接收触摸事件 */
  touch-action: pan-y;
}

.timeline-container {
  position: relative;
  padding-bottom: 80rpx;
  padding-left: 0; /* 取消左边距，完全靠布局撑开 */
}

.timeline-item {
  display: flex;
  position: relative;
  margin-bottom: 0;
  padding-bottom: 40rpx; /* 调整卡片间距 48rpx -> 40rpx */
}
.timeline-item:last-child {
  padding-bottom: 0;
}
.timeline-item:last-child .line {
  display: none;
}
/* 左侧：轴线 */
.timeline-axis {
  width: 48rpx; /* 减小宽度 60rpx -> 48rpx */
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  margin-right: 16rpx; /* 减小间距 20rpx -> 16rpx */
  flex-shrink: 0;
  padding-top: 24rpx;
}

.dot {
  width: 12rpx; /* 减小圆点 14rpx -> 12rpx */
  height: 12rpx;
  background: #D1D1D6;
  border-radius: 50%;
  z-index: 2;
  position: relative;
  transition: all 0.3s;
}

/* 最新节点样式 */
.dot.active {
  width: 20rpx; /* 减小激活圆点 24rpx -> 20rpx */
  height: 20rpx;
  background: #007AFF;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.2); /* 减小光环 */
  transform: scale(1.0);
}

.line {
  position: absolute;
  top: 36rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #E5E5EA;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

/* 右侧：内容容器 */
.timeline-content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx; /* 调整内边距 */
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
  border: 1rpx solid rgba(0,0,0,0.02);
}

/* 激活状态文本（最新一条） */
.timeline-content-wrapper.active {
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.08); /* 减淡阴影 */
  border: 1rpx solid rgba(0, 122, 255, 0.08);
}

.timeline-content-wrapper.active .time-full {
  color: #007AFF;
  font-weight: 600;
}
.timeline-content-wrapper.active .desc-text {
  color: #1D1D1F;
  font-weight: 500;
}

/* 时间行 */
.timeline-header {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.time-full {
  font-size: 22rpx; /* 减小字号 26rpx -> 22rpx */
  color: #8E8E93;
  font-family: 'SF Pro Text', sans-serif;
  letter-spacing: 0;
}

/* 内容行 */
.timeline-body {
  width: 100%;
}

.desc-text {
  font-size: 26rpx; /* 减小字号 28rpx -> 26rpx */
  color: #3A3A3C;
  text-align: justify;
  line-height: 1.5; /* 增加行高 */
  letter-spacing: 0;
  display: block;
  word-break: break-all;
}

/* 无轨迹信息 */
.logistics-empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* ======================= */
/* 🔴 权限拒绝提示弹窗样式 (复用 scan 页) */
/* ======================= */
.password-modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(10px); z-index: 10001 !important; /* 🔴 修复：确保权限教程弹窗在绑定设备弹窗之上 */
  display: flex; align-items: center; justify-content: center;
  animation: dialogMaskFadeIn 0.25s ease-out forwards;
}
.password-modal-mask.closing {
  animation: dialogMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes dialogMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.password-box {
  width: 620rpx; background: #FFFFFF; border-radius: 50rpx; padding: 50rpx 40rpx;
  display: flex; flex-direction: column; align-items: center; box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.2);
  animation: dialogBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  box-sizing: border-box;
}
.password-modal-mask.closing .password-box {
  animation: dialogBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes dialogBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}

.pass-title { font-size: 36rpx; font-weight: 800; color: #1c1c1e; margin-bottom: 30rpx; }
.pass-desc { font-size: 26rpx; color: #888; margin-bottom: 40rpx; text-align: center; line-height: 1.6; white-space: pre-wrap; }
.pass-btns { width: 100%; display: flex; gap: 30rpx; }
.p-btn {
  flex: 1; height: 100rpx; border-radius: 50rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 700; transition: opacity 0.2s;
}
.p-btn:active { transform: scale(0.97); }
.p-btn.cancel { background: #F5F5F7; color: #8E8E93; }
.p-btn.confirm { background: #1C1C1E; color: #FFFFFF; box-shadow: 0 10rpx 30rpx rgba(28, 28, 30, 0.3); }
.p-btn.full-width { flex: 1; width: 100%; }
.p-btn.disabled { 
  opacity: 0.5; 
  pointer-events: none; 
  background: #8E8E93 !important; 
}

