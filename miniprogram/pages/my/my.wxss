/* ================= 上传选项弹窗（经典黑白·实心版） ================= */
.upload-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.upload-modal-content {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 0;
  animation: popIn 0.3s cubic-bezier(0.19, 1, 0.22, 1);
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

@keyframes popIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* 选项区域容器 */
.upload-options-container {
  background: #FFFFFF;
  padding-bottom: 20rpx;
}

.upload-modal-title {
  font-size: 30rpx;
  color: #1D1D1F;
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-weight: 600;
}

.upload-options-list {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 70rpx;
  padding: 30rpx 40rpx 50rpx;
}

.upload-option-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  padding: 0;
  width: 160rpx;
  transition: all 0.2s ease;
}

.upload-option-card:active {
  transform: scale(0.92);
  opacity: 0.7;
}

/* 图标容器 - 浅灰背景，柔和 */
.upload-option-icon-wrapper {
