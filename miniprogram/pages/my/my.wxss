/* ========================================= */
/* 蓝牙雷达按钮：Apple AirDrop 风格 */
/* ========================================= */

.bt-scan-container {
  display: flex; flex-direction: column; align-items: center;
  margin: 80rpx 0; /* 上下留白加大 */
}

/* 1. 外层容器 */
.radar-circle {
  width: 200rpx; height: 200rpx; /* 整体加大，显得大气 */
  position: relative;
  display: flex; align-items: center; justify-content: center;
}

/* 2. 核心黑球 */
.radar-core {
  width: 120rpx; height: 120rpx; 
  background: #000; /* 纯黑 */
  border-radius: 50%; 
  z-index: 20; /* 确保在波纹上面 */
  display: flex; align-items: center; justify-content: center;
  
  /* 加一个高级的投影 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.25);
  transition: transform 0.2s;
}
/* 按下去的时候稍微缩一下，有反馈感 */
.radar-circle:active .radar-core {
  transform: scale(0.95);
}

/* 3. 蓝牙图标 (Base64图片) */
.bt-icon-img {
  width: 50rpx; height: 50rpx;
}

/* 4. 波纹圈 (极细线条) */
.radar-ring {
  position: absolute; 
  top: 50%; left: 50%;
  transform: translate(-50%, -50%); /* 物理居中 */
  width: 120rpx; height: 120rpx;    /* 初始大小和黑球一样 */
  
  border-radius: 50%; 
  border: 1px solid rgba(0, 0, 0, 0.1); /* 极细的淡灰色线条 */
  background: transparent;
  box-sizing: border-box;
  opacity: 0;
  z-index: 10;
}

/* 5. 动画逻辑 (只有 isScanning 时才动) */
.radar-ring.anim { 
  animation: airDropRipple 2.5s cubic-bezier(0.25, 0.8, 0.25, 1) infinite; 
}

/* 错开时间，制造连贯感 */
.r1 { animation-delay: 0s; }
.r2 { animation-delay: 0.8s; }
.r3 { animation-delay: 1.6s; }

/* 动画关键帧：像水波一样扩散 */
@keyframes airDropRipple {
  0% {
    width: 120rpx; height: 120rpx;
    opacity: 0.6;
    border-color: rgba(0, 0, 0, 0.3);
  }
  100% {
    width: 300rpx; height: 300rpx; /* 扩散得更远 */
    opacity: 0;
    border-color: rgba(0, 0, 0, 0);
  }
}

/* 底部提示文字 */
.radar-tip {
  margin-top: 50rpx; 
  color: #888; 
  font-size: 26rpx; 
  font-weight: 500;
  letter-spacing: 2rpx;
}

