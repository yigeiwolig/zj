  animation: airDropRipple 2.5s cubic-bezier(0.25, 0.8, 0.25, 1) infinite; 
}

/* 错开时间，制造连贯感 */
.r1 { animation-delay: 0s; }
.r2 { animation-delay: 0.8s; }
.r3 { animation-delay: 1.6s; }

/* 动画关键帧：像水波一样扩散 */
@keyframes airDropRipple {
  0% {
    width: 120rpx; height: 120rpx;
    opacity: 0.6;
    border-color: rgba(0, 0, 0, 0.3);
  }
  100% {
    width: 300rpx; height: 300rpx; /* 扩散得更远 */
    opacity: 0;
    border-color: rgba(0, 0, 0, 0);
  }
}

