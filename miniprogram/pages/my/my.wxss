}

.countdown-days {
  font-size: 64rpx;
  font-weight: 800;
  color: #FF3B30;
  line-height: 1;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.countdown-days.overdue {
  color: #FF3B30;
  animation: pulseRed 2s ease-in-out infinite;
}

.countdown-days::after {
  content: '天';
  font-size: 28rpx;
  color: #FF3B30;
  font-weight: 600;
  margin-left: 6rpx;
}

.countdown-warning {
  background: #FFF0E8;
  border-left: none;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #FF6B00;
  font-weight: 500;
  line-height: 1.5;
  white-space: normal;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.countdown-warning::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 24rpx;
  background: #FF9500;
  border-radius: 4rpx;
  vertical-align: middle;
  margin-right: 12rpx;
  margin-top: -4rpx;
}

.countdown-warning.overdue {
  background: #FFF0F0;
  color: #FF3B30;
}

.countdown-warning.overdue::before {
  background: #FF3B30;
}

@keyframes pulseRed {
  0%, 100% { 
    opacity: 1;
    transform: scale(1);
  }
  50% { 
    opacity: 0.85;
    transform: scale(1.05);
  }
}

