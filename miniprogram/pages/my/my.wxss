/* 页面背景（避免使用 page 标签选择器以符合组件 WXSS 规范） */
.container {
  background: #F7F7F7;
  color: #1D1D1F;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 弹窗显示时锁定页面滚动和点击 */
.container.modal-open {
  height: 100vh;
  overflow: hidden !important;
  /* 🔴 修复：移除 position: fixed，改用其他方式锁定滚动，避免页面卡住 */
  /* position: fixed; */
  width: 100%;
  touch-action: none !important;
  position: relative;
  /* 阻止页面滚动和点击穿透 */
  pointer-events: auto;
}

/* ================= 本页自定义加载动画（白色虚化 + 你的 loader） ================= */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  z-index: 10000000000 !important; /* 🔴 修复：确保在所有弹窗之上，包括地址填写弹窗 */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden; /* 防止页面滚动 */
}

.loader {
  width: 600rpx;
  height: 260rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-evenly;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
  box-sizing: border-box;
}

.loading-bar {
  width: 100%;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.loading-bar::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: #1c1c1e;
  border-radius: 20rpx;
  z-index: 1;
  animation: loadingBar 0.6s alternate infinite ease-in-out;
}

.loader-label {
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 700;
  animation: labelBlink 0.6s alternate infinite;
}

@keyframes labelBlink {
  from { opacity: 0.35; }
  to   { opacity: 1; }
}

@keyframes loadingBar {
  0%   { left: 0%; }
  50%  { left: 25%; }
  100% { left: 50%; }
}


