  padding: 40rpx 60rpx;
  border-radius: 24rpx;
  display: flex; flex-direction: column; align-items: center;
  backdrop-filter: blur(10px); /* 磨砂玻璃效果 */
}

.spinner {
  width: 60rpx; height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.2); /* 轨道颜色 */
  border-top-color: #fff; /* 转动部分纯白 */
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
