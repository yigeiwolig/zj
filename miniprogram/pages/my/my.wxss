.radar-circle:active .radar-core {
  transform: scale(0.95);
}

/* 3. 蓝牙图标 (Base64图片) */
.bt-icon-img {
  width: 50rpx; height: 50rpx;
}

/* 4. 波纹圈 (极细线条) */
.radar-ring {
  position: absolute; 
  top: 50%; left: 50%;
  transform: translate(-50%, -50%); /* 物理居中 */
  width: 120rpx; height: 120rpx;    /* 初始大小和黑球一样 */
  
  border-radius: 50%; 
  border: 1px solid rgba(0, 0, 0, 0.1); /* 极细的淡灰色线条 */
  background: transparent;
  box-sizing: border-box;
  opacity: 0;
  z-index: 10;
}

/* 5. 动画逻辑 (只有 isScanning 时才动) */
