}

/* 2. 核心黑球 */
.radar-core {
  width: 120rpx; height: 120rpx; 
  background: #000; /* 纯黑 */
  border-radius: 50%; 
  z-index: 20; /* 确保在波纹上面 */
  display: flex; align-items: center; justify-content: center;
  
  /* 加一个高级的投影 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.25);
  transition: transform 0.2s;
}
