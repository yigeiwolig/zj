/* ================= 自动消失提示样式（无按钮，3秒后自动消失，带收缩退出动画） ================= */
.auto-toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 10000000004 !important; /* 🔴 修复：确保在所有弹窗之上，包括填写售后单弹窗（最高层级） */
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto !important; /* 🔴 修复：允许点击，确保弹窗可见 */
  overflow: hidden; /* 防止页面滚动 */
  animation: autoToastMaskFadeIn 0.25s ease-out forwards;
}
.auto-toast-mask.closing {
  animation: autoToastMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes autoToastMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.auto-toast-box {
  background: #fff; /* 🔴 改为纯白色背景 */
  border-radius: 32rpx;
  padding: 48rpx 56rpx;
  max-width: 640rpx;
  min-width: 480rpx;
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.12),
    0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: autoToastFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 移除自动退出，改为手动触发 */
  position: relative;
  z-index: 10000000005 !important; /* 🔴 修复：确保 toast 内容在最上层（最高层级） */
  pointer-events: auto !important; /* 🔴 修复：确保内容可交互 */
  overflow: hidden;
}
.auto-toast-mask.closing .auto-toast-box {
  animation: autoToastShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}

/* 添加微妙的边框 */
.auto-toast-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(0, 0, 0, 0.05));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

@keyframes autoToastFadeIn {
  from {
    opacity: 0;
    transform: translateY(-30rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* autoToastFadeOut 已移除，改用 autoToastShrinkOut（手动触发） */

