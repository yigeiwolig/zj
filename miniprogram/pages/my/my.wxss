}
/* 🔴 统一返回键样式 - 全局标准 */
.back-icon {
  position: absolute;
  left: 40rpx;
  top: calc(env(safe-area-inset-top, 0px) + 20rpx); /* 🔴 减少顶部间距 */
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

