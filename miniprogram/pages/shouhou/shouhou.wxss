.shutter-outer {
  width: 150rpx;
  height: 150rpx;
  border: 8rpx solid rgba(255, 255, 255, 1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.shutter-outer:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.shutter-inner {
  width: 120rpx;
  height: 120rpx;
  background: #FF3B30;
  border-radius: 60rpx;
  transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1),
