/* 🔴 新增：录制全屏页样式（参考 case 页面） */
/* ================================================= */
.camera-full-screen {
  position: fixed; 
  top: 0; 
  left: 0; 
  width: 100vw; 
  height: 100vh; 
  z-index: 3000; 
  background: #000;
  touch-action: none;
  overflow: hidden;
  will-change: transform, opacity, border-radius;
  transform: translateZ(0);
  transform-origin: center bottom;
  transform: scale(0.05);
  opacity: 0;
  border-radius: 50%;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
              opacity 0.2s ease-out,
              border-radius 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.camera-full-screen.animating {
  transform: scale(0.05);
  opacity: 0;
  border-radius: 50%;
}

.camera-full-screen.animated {
  transform: scale(1);
  opacity: 1;
  border-radius: 0;
}

.cam-overlay {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  pointer-events: none;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
}

.rec-header-layout {
  position: absolute;
  top: 120rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
