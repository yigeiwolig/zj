}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #FF3B30;
  opacity: 0;
  transition: opacity 0.15s;
}

.rec-dot.active {
  opacity: 1;
  animation: blinkDot 1s infinite;
}

@keyframes blinkDot {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

.rec-time-text {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 500;
