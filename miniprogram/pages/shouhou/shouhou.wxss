page {
  background-color: #F2F2F7;
  font-family: -apple-system, Helvetica, sans-serif;
}

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* === 首页视图 === */
.home-view {
  width: 100%;
  height: 100%;
  padding-top: 200rpx;
  padding-bottom: 50px;
  overflow-y: auto;
  transition: transform 0.4s ease, opacity 0.4s ease;
  background-color: #F2F2F7;
  box-sizing: border-box;
}

.home-view.shrink {
  transform: scale(0.92);
  opacity: 0;
  pointer-events: none;
}

/* 顶部导航 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding-left: 40rpx; 
  padding-right: 40rpx;
  box-sizing: border-box; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  z-index: 10000;
  pointer-events: none;
  background: transparent;
}

.back-icon {
  position: absolute;
  left: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
}
.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}

.nav-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
  background: rgba(242, 242, 247, 0.9);
  backdrop-filter: blur(20px);
  z-index: 100;
}

.brand-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
  font-size: 38rpx;
  font-weight: 800;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  pointer-events: auto;
}

/* 管理员切换按钮 */
.admin-toggle-btn {
  display: inline-block;
  margin-left: 20rpx;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  color: #8E8E93;
  border: 1rpx solid #E5E5EA;
  vertical-align: middle;
  transition: all 0.3s;
  font-weight: 600;
}

.admin-toggle-btn.on {
  background: #000;
  color: #fff;
  border-color: #000;
}

.nav-back-btn .back-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}

.nav-back-btn .back-icon::before {
  display: none; /* 禁用伪元素，使用文字符号 */
  transform: translate(-50%, -50%) rotate(45deg);
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #1D1D1F;
  border-bottom: 3rpx solid #1D1D1F;
  border-radius: 2rpx;
}

.header-title-row {
  position: absolute;
  left: 50%;
  /* 🔴 使用动态计算，通过内联样式设置 top */
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.large-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1D1D1F;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

/* 管理员切换按钮 */
.admin-toggle-btn {
  display: inline-block;
  margin-left: 20rpx;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  color: #8E8E93;
  border: 1rpx solid #E5E5EA;
  vertical-align: middle;
  transition: all 0.3s;
  font-weight: 600;
  pointer-events: auto;
}

/* 开启状态的颜色 */
.admin-toggle-btn.on {
  background: #000;
  color: #fff;
  border-color: #000;
}

.subtitle {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 10rpx;
  text-align: center;
}

.nav-right-placeholder {
  width: 64rpx;
  flex-shrink: 0;
}

/* 管理员功能区域（独立容器） */
.admin-actions-container {
  padding: 0 40rpx 20rpx 40rpx;
  background-color: #F2F2F7;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 退出管理员按钮 */
.exit-admin-btn {
  padding: 16rpx 32rpx;
  background: rgba(255, 59, 48, 0.1);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: 1rpx solid rgba(255, 59, 48, 0.3);
}

.exit-admin-btn:active {
  background: rgba(255, 59, 48, 0.2);
  transform: scale(0.98);
}

.exit-icon {
  font-size: 28rpx;
  color: #FF3B30;
  font-weight: 600;
}

.admin-badge {
  font-size: 20rpx;
  background: #FF3B30;
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  vertical-align: middle;
}

/* 管理员同步按钮 */
.sync-parts-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  background: #007AFF;
  color: #fff;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.sync-parts-btn:active {
  background: #0051D5;
  transform: scale(0.98);
}

.sync-icon {
  font-size: 28rpx;
}

.sync-text {
  font-size: 26rpx;
}

.section-title {
  padding: 0rpx 40rpx 20rpx 40rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #86868B;
  letter-spacing: 2rpx;
}

.card-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 40rpx;
  margin-bottom: 60rpx; /* 增大卡片组之间的间距 */
}

/* === 卡片核心样式修复 === */
.i-card {
  width: 48%;
  height: 320rpx;
  border-radius: 36rpx;
  position: relative; /* 关键：作为定位基准 */
  overflow: hidden;   /* 关键：切掉溢出的圆圈 */
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}

/* 确保文字在圆圈上面 */
.card-top,
.card-btm {
  position: relative;
  z-index: 2; /* 文字层级高 */
}

/* 圆形装饰 */
.circle-decor {
  position: absolute;
  bottom: -40rpx;
  right: -40rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  z-index: 1; /* 在文字下面 */
}

/* 白色卡片 (PRO) 配色 */
.style-white {
  background: #FFFFFF;
  color: #000;
}
.style-white .badge {
  background: #F2F2F7;
  color: #000;
}
.style-white .circle-decor {
  background: #F2F2F7;
}

/* 黑色卡片 (MAX) 配色 */
.style-black {
  background: #1C1C1E;
  color: #FFF;
}
.style-black .badge {
  background: #333;
  color: #D1D1D6;
}
.style-black .p-desc {
  color: #888;
}
.style-black .circle-decor {
  background: #2C2C2E;
}

.badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}
.p-name {
  font-size: 36rpx;
  font-weight: 700;
}
.p-desc {
  font-size: 24rpx;
  margin-top: 6rpx;
  color: #86868B;
}

/* === 二级页面视图 === */
.detail-view {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: #FFFFFF;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  z-index: 100;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 防止整体滚动 */
  box-sizing: border-box;
  /* padding-top 通过内联样式动态设置，使用 statusBarHeight */
  /* 高度会自动减去 padding-top，因为 box-sizing: border-box */
}

.detail-view.slide-in {
  transform: translateX(0);
  z-index: 200; /* 确保从「去购买配件」进入时盖住首页 */
}

.detail-nav {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx 10rpx 30rpx; /* 增加顶部间距 */
  border-bottom: 1rpx solid #F2F2F7;
  background: rgba(255,255,255,0.95);
  position: relative;
  z-index: 999; /* 确保层级最高 */
  flex-shrink: 0; /* 防止被压缩 */
}
/* 返回按钮 - 仅图标，无背景 */
.nav-back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: transparent;
  transition: all 0.2s;
  cursor: pointer;
}

.nav-back-btn:active {
  opacity: 0.6;
  transform: scale(0.96);
}

/* 返回箭头图标 - 统一使用文字符号 */
.back-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
  margin-left: -4rpx; /* 微调位置，让箭头更居中 */
}

.back-icon::before {
  display: none; /* 禁用伪元素，使用文字符号 */
}

.nav-title { 
  font-size: 32rpx; 
  font-weight: 700; 
  color: #1D1D1F;
}

.content-scroll {
  flex: 1;
  overflow-y: scroll;
  padding: 30rpx;
  padding-bottom: 180rpx; /* 为底部提交栏留出空间，减少空白 */
  -webkit-overflow-scrolling: touch; /* iOS 平滑滚动 */
  height: 0; /* 关键：配合 flex: 1 使用，确保正确计算高度 */
  min-height: 0; /* 防止 flex 子元素溢出 */
}

/* Tabs */
.tab-group {
  display: flex;
  background: #F2F2F7;
  padding: 8rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #86868B;
  border-radius: 20rpx;
}
.tab-item.active {
  background: #FFFFFF;
  color: #000;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

/* 服务切换 */
.svc-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.svc-item {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  background: #F9F9F9;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 4rpx solid transparent;
}
.svc-item.selected {
  background: #F0F8FF;
  border-color: #007AFF;
  color: #007AFF;
}

/* 配件网格 */
.section-label {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 700;
  margin-bottom: 20rpx;
}

/* 首页一键同步数据按钮容器 */
.sync-all-container {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 首页一键同步数据按钮 */
.sync-all-btn {
  background: #000;
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}
.sync-all-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}
.parts-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
/* 卡片包装器 */
.part-tag-wrapper {
  width: 30%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.part-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx; /* 增加上下padding */
  background: #FFFFFF; /* 纯白背景，干净 */
  border: 2rpx solid #F0F0F0; /* 非常浅的边框 */
  border-radius: 12rpx;
  width: 100%;
  min-height: 140rpx; /* 最小高度，确保文字有足够空间 */
  box-sizing: border-box;
  position: relative;
  text-align: center;
  transition: all 0.2s ease;
  transform: scale(1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04); /* 更轻的阴影，不会脏 */
}

/* 拖动中的样式 */
.part-tag.dragging {
  box-shadow: 0 16rpx 48rpx rgba(0, 122, 255, 0.4);
  transform: scale(1.08) rotate(2deg);
  transition: none !important; /* 拖动时禁用过渡 */
}

/* 占位符 */
.part-tag-placeholder {
  width: 100%;
  min-height: 140rpx;
  border: 2rpx dashed #007AFF;
  border-radius: 12rpx;
  background: rgba(0, 122, 255, 0.05);
  box-sizing: border-box;
}
.part-tag text {
  text-align: center;
  width: 100%;
  font-size: 26rpx;
  font-weight: 600; /* 加粗，更明显 */
  line-height: 1.5; /* 行高，允许换行 */
  color: #000333; /* 柔和的深灰色，不脏 */
  word-break: break-all; /* 允许长单词换行 */
  word-wrap: break-word; /* 允许在单词内换行 */
  display: -webkit-box;
  -webkit-line-clamp: 2; /* 最多显示2行 */
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.part-tag.active text {
  color: #007AFF; /* 选中时文字颜色 */
  font-weight: 700; /* 选中时更粗 */
}
.part-tag:active {
  transform: scale(0.95);
  opacity: 0.8;
}
/* 用户点击选中：蓝色实线边框 */
.part-tag.active {
  background: #F0F8FF; /* 非常浅的蓝色背景，干净明亮 */
  border-color: #007AFF;
  border-width: 3rpx; /* 选中时边框更粗 */
  color: #007AFF;
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.15); /* 柔和的蓝色阴影，不脏 */
}

/* 管理员要求购买：细虚线 + 呼吸动画，与点击选中区分 */
.part-tag.preselected {
  border: 2rpx dashed rgba(0, 122, 255, 0.55);
  background: #FAFCFF;
  animation: part-tag-breathe 2s ease-in-out infinite;
  animation-delay: 0;
}
.part-tag.preselected text { color: #333; }
.part-tag.preselected .part-price { color: #007AFF !important; }
/* 呼吸动画：2s 周期，与 JS 延迟标 preselected 配合实现多块同相 */
@keyframes part-tag-breathe {
  0%, 100% {
    box-shadow: 0 2rpx 12rpx rgba(0, 122, 255, 0.12);
    transform: scale(1);
    border-color: rgba(0, 122, 255, 0.5);
  }
  50% {
    box-shadow: 0 8rpx 28rpx rgba(0, 122, 255, 0.28);
    transform: scale(1.02);
    border-color: rgba(0, 122, 255, 0.85);
  }
}
.part-tag.preselected.active {
  border: 3rpx solid #007AFF;
  background: #F0F8FF;
  animation: none;
}
.part-tag.preselected.active text { color: #007AFF; }
.part-tag.preselected.active .part-price { color: #007AFF !important; }

/* 管理员预选但用户未勾选：红色提醒 */
.part-tag.preselected-unchecked {
  border-color: #E53935 !important;
  background: #FFF5F5 !important;
}
.part-tag.preselected-unchecked text { color: #C62828 !important; }
.part-tag.preselected-unchecked .part-price { color: #E53935 !important; }
.part-tag.preselected-unchecked.preselected {
  border-color: rgba(229, 57, 53, 0.8) !important;
}

/* 管理员添加配件按钮 */
.add-part-btn {
  border: 2rpx dashed #007AFF !important;
  background: #F5FAFF !important;
  cursor: pointer;
}
.add-part-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}
.part-price {
  font-size: 26rpx; /* 稍微增大价格字体 */
  font-weight: 700;
  margin-top: 10rpx;
  color: #007AFF !important; /* 强制蓝色，防止被覆盖 */
  text-align: center;
}
.part-tag.active .part-price { 
  color: #007AFF !important; /* 选中时也是蓝色 */
  font-weight: 800; /* 选中时价格更粗 */
}

/* 管理员改价/改名图标 - 移到右下角 */
.admin-edit-price {
  position: absolute;
  /* 原来是 top: 4rpx; right: 4rpx; */
  /* 现在改成右下角 */
  bottom: 10rpx; 
  right: 10rpx;
  
  font-size: 20rpx;
  background: #007AFF; /* 改成蓝色，更协调 */
  color: #fff;
  width: 36rpx;       /* 稍微加大一点，好点 */
  height: 36rpx;
  border-radius: 50%;
  text-align: center; 
  line-height: 36rpx;
  z-index: 999;         /* 提高 z-index，确保在最上层 */
  opacity: 1;           /* 改为完全不透明，确保可见 */
  pointer-events: auto; /* 明确允许点击事件 */
  cursor: pointer;      /* 显示手型指针 */
}
/* 排序标识（左上角） */
.sort-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  font-size: 28rpx;
  color: #007AFF;
  opacity: 0.7;
  z-index: 3;
  pointer-events: none;
}
/* 拖动时隐藏排序标识 */
.part-tag.dragging .sort-indicator {
  opacity: 0;
}
.del-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF3B30;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-btn-dashed {
  padding: 20rpx 30rpx;
  border: 2rpx dashed #999;
  border-radius: 40rpx;
  color: #000;
  font-size: 24rpx;
}

/* 表单输入 */
.input-area {
  width: 100%;
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* === 联系信息板块 === */
.contact-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-top: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
  padding: 30rpx;
}

/* 头部 */
.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.smart-paste {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 600;
  padding: 10rpx 20rpx;
  background: #F0F8FF;
  border-radius: 30rpx;
}

.input-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 修复输入框显示异常 */
.input-field {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #000;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.input-field:last-child {
  margin-bottom: 0;
}

.ph-style {
  color: #AEAEB2;
}
.upload-box {
  border: 4rpx dashed #C7C7CC;
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-sub {
  font-size: 22rpx;
  color: #8E8E93;
}

.upload-selected {
  width: 100%;
}

.upload-preview-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111;
  color: #fff;
  font-size: 26rpx;
}

.upload-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.upload-preview-container {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
