/* 1. 遮罩层 */
.dark-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(3px); z-index: 550;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* 2. 半屏弹窗主体 */
.full-screen-overlay {
  position: fixed; bottom: 0; left: 0; width: 100%; height: 85%;
  background: #F5F5F7; border-radius: 40rpx 40rpx 0 0;
  transform: translateY(110%); transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 600; display: flex; flex-direction: column; overflow: hidden;
}
.full-screen-overlay.active { transform: translateY(0); }

/* 3. 底部双按钮容器 */
.checkout-footer-dual {
  position: absolute; bottom: 0; left: 0; width: 100%;
  background: #FFFFFF; 
  padding: 20rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee; display: flex; gap: 20rpx; box-sizing: border-box;
  z-index: 601;
}

/* 4. 按钮样式 */
.btn-custom {
  flex: 1; background: #F0F8FF; color: #007AFF;
  border-radius: 20rpx; height: 90rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.btn-pay {
  flex: 1.5; background: #000; color: #fff;
  border-radius: 20rpx; height: 90rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.btn-main { font-size: 30rpx; font-weight: 700; }

/* ================= 自定义弹窗样式（带弹出+收缩退出动画） ================= */
.custom-dialog-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);
  z-index: 999999999; display: flex; align-items: center; justify-content: center;
  animation: dialogMaskFadeIn 0.25s ease-out forwards;
}
.custom-dialog-mask.closing {
  animation: dialogMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes dialogMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.custom-dialog-box {
  width: 600rpx; background: #fff; border-radius: 40rpx; padding: 60rpx 50rpx 50rpx;
  display: flex; flex-direction: column; align-items: center; text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  animation: dialogBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
.custom-dialog-mask.closing .custom-dialog-box {
  animation: dialogBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes dialogBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}
.cd-title { 
  font-size: 36rpx; 
  font-weight: 700; 
  margin-bottom: 30rpx; 
  color: #000; /* 🔴 改为纯黑色 */
  letter-spacing: 0.5rpx;
}
.cd-content { 
  font-size: 30rpx; 
  color: #000; /* 🔴 改为纯黑色 */
  margin-bottom: 60rpx; 
  line-height: 1.8; 
  letter-spacing: 0.5rpx;
  padding: 0 10rpx;
}
.cd-btn-row { width: 100%; display: flex; gap: 30rpx; }
.cd-btn { 
  flex: 1; 
  height: 88rpx; 
  line-height: 88rpx; 
  border-radius: 44rpx; 
  font-size: 30rpx; 
  font-weight: 600; 
  transition: all 0.2s;
}
.cd-btn.cancel { background: #F5F5F7; color: #000; }
.cd-btn.confirm { 
  background: #000; 
  color: #fff; 
}
.cd-btn:active { opacity: 0.8; transform: scale(0.98); }
@keyframes popIn { 
  from {
    transform: scale(0.95); 
    opacity: 0;
  } 
  to {
    transform: scale(1); 
    opacity: 1;
  } 
}

/* ================= 自动消失提示样式（无按钮，3秒后自动消失，带收缩退出动画） ================= */
.auto-toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 99999999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none; /* 允许点击穿透 */
  animation: autoToastMaskFadeIn 0.25s ease-out forwards;
}
.auto-toast-mask.closing {
  animation: autoToastMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes autoToastMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.auto-toast-box {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 32rpx;
  padding: 48rpx 56rpx;
  max-width: 640rpx;
  min-width: 480rpx;
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.12),
    0 8rpx 24rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  animation: autoToastFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 移除自动退出，改为手动触发 */
  position: relative;
  overflow: hidden;
}
.auto-toast-mask.closing .auto-toast-box {
  animation: autoToastShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}

/* 添加微妙的边框 */
.auto-toast-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(0, 0, 0, 0.05));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

@keyframes autoToastFadeIn {
  from {
    opacity: 0;
    transform: translateY(-30rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

