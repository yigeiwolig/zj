}
.na-close-icon:active {
  color: #000;
  transform: scale(0.9);
}

/* 顶部标题区 - 科技风 */
.na-header-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;
  width: 100%;
  z-index: 1;
}

.na-main-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #111111; /* 白卡片上使用深色标题 */
  letter-spacing: 2rpx;
  text-align: center;
  line-height: 1;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.na-tag-line {
  font-size: 20rpx;
  font-weight: 600;
  color: #8E8E93; /* 中灰副标题 */
  letter-spacing: 6rpx;
  text-transform: uppercase;
  text-align: center;
}

/* 轮播区 */
.na-swiper {
  width: 100%;
  height: 720rpx; /* 再次加高，全屏海报感 */
  margin-bottom: 56rpx;
  z-index: 1;
}

.na-swiper-item {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 单个卡片 - 纯白高级质感 */
.na-card {
  width: 100%;
  height: 100%;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-radius: 40rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  position: relative;
  /* 改弱阴影，避免出现一圈明显的灰边 */
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  transform: translateZ(0);
}

/* 图片区域 - 留出白边 */
.na-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 30rpx;
}

/* 卡片遮罩浮层：只覆盖图片底部区域 */
.na-card-overlay {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 22rpx;
  height: 34%;
  border-radius: 0 0 30rpx 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.0) 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

/* NEW 徽章 - 动态呼吸 */
.na-badge {
  background: #fff;
  color: #000;
  font-size: 18rpx;
  font-weight: 900;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 0 20rpx rgba(255,255,255,0.4);
  animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
  0% { transform: scale(1); box-shadow: 0 0 20rpx rgba(255,255,255,0.4); }
  50% { transform: scale(1.05); box-shadow: 0 0 40rpx rgba(255,255,255,0.7); }
  100% { transform: scale(1); box-shadow: 0 0 20rpx rgba(255,255,255,0.4); }
}

.na-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.3;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.5);
}

/* 按钮 - 极简白块 */
.na-jump-btn {
  width: 380rpx;
  height: 100rpx;
  border-radius: 999rpx; /* 椭圆胶囊按钮 */
  /* 轻微立体感：上亮下暗的渐变 + 更实在的阴影和描边 */
  background: linear-gradient(180deg, #FFFFFF 0%, #F3F3F3 100%);
  color: #000;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.16);
  border: 1rpx solid rgba(0,0,0,0.08);
  transition: transform 0.1s;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  letter-spacing: 2rpx;
  z-index: 1;
  gap: 16rpx;
}

.na-jump-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.na-jump-btn::after {
  border: none;
}

.btn-arrow {
  font-size: 32rpx;
  line-height: 1;
  font-weight: 300;
  transform: translateY(-2rpx); /* 微调对齐 */
}

@keyframes naPopIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.loading-bar {
  width: 100%;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}
.loading-bar::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: #1c1c1e;
  border-radius: 20rpx;
  animation: loadingBar 0.6s alternate infinite ease-in-out;
}
.loader-label {
  color: #1c1c1e;
  font-size: 28rpx;
  animation: labelBlink 0.6s alternate infinite;
}

@keyframes labelBlink {
  from { opacity: 0.3; }
  to   { opacity: 1; }
}
@keyframes loadingBar {
  0%   { left: 0%; }
  50%  { left: 25%; }
  100% { left: 50%; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ================= 底部触发按钮 (New) ================= */
.trigger-button {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx); /* 适配全面屏 */
  left: 50%;
  
  /* 初始状态：隐藏在下方，透明 */
  transform: translateX(-50%) translateY(200%);
  opacity: 0;

  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 24rpx 48rpx;
  border-radius: 60rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
  z-index: 400; /* 低于抽屉 */
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.5);
  
  /* 移除原来的 animation，改用 transition 控制所有状态变化 */
  transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
}

/* 状态1：弹起可见 */
.trigger-button.visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

/* 状态2：变淡沉下 (闲置状态) */
.trigger-button.faded {
  transform: translateX(-50%) translateY(30%); /* 下沉 30% */
  opacity: 0.6; /* 变半透明 */
  background: rgba(255, 255, 255, 0.75); /* 背景也淡一点 */
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); /* 阴影减弱 */
  filter: grayscale(0.2); /* 轻微置灰 */
}

/* 交互反馈：即使是 faded 状态，按下去也要变清楚 */
.trigger-button:active,
.trigger-button.faded:active {
  transform: translateX(-50%) scale(0.95) translateY(0); /* 按下时回弹一点 */
  background: rgba(255, 255, 255, 1);
  opacity: 1;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  filter: grayscale(0);
}

.trigger-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 8rpx;
  line-height: 1; /* 🔴 修正：强制行高为1，确保垂直居中 */
  padding-top: 2rpx; /* 微调：汉字视觉中心修正 */
}

.trigger-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

