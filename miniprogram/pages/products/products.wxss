/* ================= 底部抽屉样式 ================= */
.bottom-drawer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 85vh; /* 抽屉展开高度 */
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.08);
  z-index: 500; /* 高于其他元素 */
  
  /* 🔴 修改：初始完全隐藏 */
  transform: translateY(100%); 
  
  transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  display: flex;
  flex-direction: column;
}

.bottom-drawer.open {
  transform: translateY(0);
}

/* 把手区域 - 仅用于关闭和指示 */
.drawer-handle-area {
  height: 80rpx; /* 减小高度，不再需要承载文字 */
  width: 100%;
  display: flex;
  justify-content: center;
  padding-top: 30rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.drawer-handle-bar {
  width: 80rpx;
  height: 10rpx;
  background: #E5E5EA;
  border-radius: 10rpx;
}

.drawer-hint-text {
  display: none; /* 隐藏原来的提示文字 */
}

/* 内容区域 */
.drawer-content {
  flex: 1;
  width: 100%;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 功能网格 - 改为长条形列表布局 */
.function-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

/* 功能卡片 - 长条形样式 */
.function-card {
  background: #ffffff;
  border: 2rpx solid #F2F2F7;
  border-radius: 32rpx;
  padding: 36rpx 48rpx; /* 增加水平内边距 */
  display: flex;
  align-items: center;
  gap: 32rpx; /* 增加图标和文字的间距 */
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
  /* 添加微阴影增加层次感 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.function-card:active {
  background: #F9F9F9;
  transform: scale(0.99); /* 微调按压缩放比例 */
}

/* 图标区域 */
.fc-icon-box {
  width: 88rpx; /* 稍微加大图标区域 */
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.fc-icon {
  width: 100%;
  height: 100%;
}

/* 文字区域 */
.fc-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1; /* 让文字区域占据剩余空间 */
  justify-content: center;
}

.fc-title {
  font-size: 32rpx; /* 稍微加大标题 */
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fc-sub {
  font-size: 20rpx;
  font-weight: 600;
  color: #86868b;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}
