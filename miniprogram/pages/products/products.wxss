/* ================= 自动消失提示（无按钮，3秒后自动消失，带收缩退出动画） ================= */
.auto-toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  animation: autoToastMaskFadeIn 0.25s ease-out forwards;
}
.auto-toast-mask.closing {
  animation: autoToastMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes autoToastMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.auto-toast-box {
  background: #fff; /* 🔴 改为白色背景 */
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 40rpx;
  max-width: 600rpx;
  text-align: center;
  animation: toastFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  pointer-events: auto;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15); /* 🔴 添加阴影 */
}
.auto-toast-mask.closing .auto-toast-box {
  animation: autoToastShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes toastFadeIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
@keyframes autoToastShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}

.at-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000; /* 🔴 改为黑色 */
  margin-bottom: 8rpx;
}

.at-content {
  font-size: 26rpx;
  color: #000; /* 🔴 改为黑色 */
  line-height: 1.5;
}

/* ================= 全局背景 (完全恢复原版) ================= */
page {
  /* 
     原版对称微蓝渐变：
     顶部纯白 -> 中间科技蓝 -> 底部纯白 
  */
  background: linear-gradient(180deg, 
    #FFFFFF 0%,
    #FFFFFF 10%,
    #F6F8FB 25%,
    #E5EEF8 45%,
    #D8E7F6 60%,
    #EEF4FA 80%,
    #FFFFFF 100%
  );
  
  height: 100%;
  overflow: hidden; 
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

/* 顶部导航 */
.header {
  position: fixed; top: 0; left: 0; right: 0; height: 180rpx;
  padding-top: calc(env(safe-area-inset-top, 0px) + 20rpx); /* 🔴 减少顶部间距 */ 
  padding-left: 40rpx; 
  padding-right: 40rpx;
  box-sizing: border-box; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  z-index: 10000; 
  pointer-events: none;
  background: transparent; 
}
/* 🔴 统一返回键样式 - 恢复原来的实现方式 */
/* 🔴 统一返回键样式 - 全局标准 */
.back-icon {
  position: absolute;
  left: 40rpx;
  top: calc(env(safe-area-inset-top, 0px) + 20rpx); /* 🔴 减少顶部间距，从 88rpx 改为 20rpx */
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

/* 统一返回箭头样式 */
.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}

/* 容器 */
.container { width: 100%; height: 100vh; position: relative; }

/* ================= 卡片通用样式 (恢复极致玻璃质感) ================= */
.card {
  position: absolute;
  left: 50%; margin-left: -310rpx;
  width: 620rpx; height: 260rpx;
  
  /* 
     === 恢复重点：原来的透明渐变 ===
     左右两边透，中间微亮
  */
  background: linear-gradient(
    90deg, 
    rgba(255, 255, 255, 0.15) 0%, 
    rgba(255, 255, 255, 0.2) 50%,
    rgba(255, 255, 255, 0.15) 100%
  );
  
  /* 强力磨砂模糊 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  
  /* 边框：半透明白边 */
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 44rpx;
  
  box-sizing: border-box;
  
  /* 投影：原来的柔和阴影 */
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.05);
  
  /* 动画设置 */
  will-change: transform, opacity;
}

/* 当前选中项 (Current) - 高亮玻璃 */
.card.curr {
  z-index: 100;
  
  /* 选中时更亮、更透 */
  background: linear-gradient(
    90deg, 
    rgba(255, 255, 255, 0.25) 0%, 
    rgba(255, 255, 255, 0.35) 50%,
    rgba(255, 255, 255, 0.25) 100%
  );
  
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  
  /* 投影加深 */
  box-shadow: 
    0 20rpx 50rpx -10rpx rgba(0, 0, 0, 0.1), 
    inset 0 0 20rpx rgba(255, 255, 255, 0.5); 
}

/* ================= 内部布局 (使用刚才修正的绝对定位) ================= */
/* 这里的布局逻辑是新的（修正位置），但样式是旧的（透明背景） */

.card-inner {
  width: 100%; height: 100%;
  position: relative; /* 设为原点 */
}

/* 1. 文字：绝对定位到左上角 */
.card-info {
  position: absolute;
  top: 60rpx;   /* 距离顶部 50rpx，往下移动一点点 */
  left: 40rpx;  /* 距离左边 50rpx */
  display: flex; 
  flex-direction: column;
  z-index: 2;
}

.card-title { 
  font-size: 40rpx; 
  font-weight: 800; 
  color: #333; 
  margin-bottom: 8rpx; 
}
.card-sub { 
  font-size: 20rpx; 
  font-weight: 700; 
  color: #556677; /* 恢复稍微深一点的灰色，防止在玻璃背景上看不清 */
  letter-spacing: 2rpx; 
  text-transform: uppercase; 
}

/* 2. 图标：绝对定位到垂直居中偏右 */
.icon-container {
  position: absolute;
  right: 10rpx;   /* 靠右，往右移动一点点 */
  top: 50%;       /* 垂直居中 */
  transform: translateY(-50%); 
  
  width: 150rpx; height: 150rpx; /* 放大一点点 */
  background: #fff; /* 图标底座保持纯白，突出质感 */
  border-radius: 44rpx;
  display: flex; justify-content: center; align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.06);
}

.svg-icon { width: 90rpx; height: 90rpx; /* 放大一点点 */ }

/* ================= 自定义加载动画 ================= */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(5px);
  z-index: 99999 !important; /* 确保在最上层，覆盖微信原生提示 */
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loader {
  width: 350rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-evenly;
  padding: 30rpx;
  box-shadow: 0 0 20rpx rgba(0,0,0,0.1);
}

/* 🆕 产品上新弹窗样式 - 5.1 暗黑流光科技风 (Dark Tech Stream - High Contrast) */
.new-arrival-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.88); /* 极深背景 */
  backdrop-filter: blur(24px);
  z-index: 1000000000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.new-arrival-box {
  width: 640rpx;
  /* 纯白主弹窗卡片 */
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 64rpx 0 64rpx;
  box-sizing: border-box;
  /* 柔和高端的阴影与边框 */
  box-shadow: 0 32rpx 90rpx rgba(0, 0, 0, 0.22);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: naPopIn 0.45s cubic-bezier(0.19, 1, 0.22, 1);
  position: relative;
  overflow: hidden;
}

/* 背景光效 */
.na-bg-glow {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0,0,0,0.03) 0%, transparent 70%);
  z-index: 0;
  pointer-events: none;
}

/* 关闭按钮 (右上角) */
.na-close-icon {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 44rpx;
