page {
  background-color: #F5F5F7;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  height: 100%;
}

/* 顶部导航（统一样式，参考 shop 页） */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding-left: 40rpx;
  padding-right: 40rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10000;
  pointer-events: none;
  background: transparent; 
}

.back-icon {
  position: absolute;
  left: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}

.nav-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
  /* 统一为淡灰色毛玻璃背景，和 shop 页一致 */
  background: rgba(245,245,247,0.9);
  backdrop-filter: blur(20px);
  z-index: 100;
}

.brand-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%) translateY(-50%);
  text-align: center;
  display: flex;
  flex-direction: column; /* 主标题 + 副标题 垂直排列 */
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  pointer-events: auto;
}

/* 主标题：MT-摩改社 */
.brand-main {
  font-size: 38rpx;
  font-weight: 800;
  color: #000;
}

/* 副标题：技术支持 */
.brand-sub {
  font-size: 22rpx;
  color: #8E8E93;
  letter-spacing: 4rpx;
}

/* 左上角返回按钮 - 统一样式 */
.back-btn {
  position: fixed;
  top: 80rpx;
  left: 48rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  cursor: pointer;
  transition: all 0.2s;
}

.back-btn:active {
  transform: scale(0.95);
  opacity: 0.7;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 顶部 padding 改为在 wxml 里用 statusBarHeight + navBarHeight 动态控制 */
  padding: 0 40rpx 80rpx;
  box-sizing: border-box;
  min-height: 100%;
}

/* --- 自定义高级 Toast 样式 (居中版) --- */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9); /* 居中定位 + 初始微缩 */
  
  background: rgba(40, 40, 40, 0.9); /* 深空灰背景，显高级 */
  backdrop-filter: blur(10px);
  
  padding: 30rpx 50rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2);
  
  display: flex;
  flex-direction: column; /* 图标文字垂直排列 */
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  
  z-index: 3000; /* 保证在所有弹窗最上面 */
  opacity: 0;
  pointer-events: none;
  transition: all 0.2s cubic-bezier(0.25, 1, 0.5, 1);
}

.custom-toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1); /* 出现时回弹正常大小 */
}

.toast-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF; /* 白字 */
  letter-spacing: 1rpx;
}

.toast-icon-box {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 原 title-header / h1 / p 系列样式已废弃，主标题统一放在导航 brand-title 中 */

.card-stack {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  justify-content: flex-start;
}

.bento-card {
  background: #FFFFFF;
  border-radius: 56rpx;
  padding: 40rpx;
  flex: 1;
  max-height: 45%;
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  /* 加强卡片的立体感，让上下两张卡片边界更清晰 */
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.10);
  border: 1rpx solid rgba(0,0,0,0.03);
  position: relative;
  transition: transform 0.2s;
}

.card-hover { transform: scale(0.98); background-color: #FAFAFA; }

.visual-area {
  flex: 1; width: 100%;
  display: flex; align-items: center; justify-content: center; position: relative;
}

/* 图标居中放大 */
.icon-layer {
  width: 180rpx; height: 180rpx;
  position: absolute;
  top: 42%; left: 50%;
  margin-left: -90rpx; margin-top: -90rpx;
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  opacity: 1; transform: scale(1);
}

.icon-text {
  position: absolute; top: 72%; width: 100%; text-align: center;
  font-size: 24rpx; color: #CCCCCC;
  transition: all 0.4s; opacity: 1;
}

.qr-layer {
  width: 320rpx; height: 320rpx; border-radius: 16rpx;
  position: absolute; transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  opacity: 0; transform: scale(0.9) translateY(20rpx); pointer-events: none;
}

.icon-layer.hidden, .icon-text.hidden { opacity: 0; transform: scale(0.8); }
.qr-layer.show { opacity: 1; transform: scale(1) translateY(0); }

.text-area { text-align: center; z-index: 2; margin-top: 20rpx; }
.card-title { font-size: 40rpx; font-weight: 600; color: #1D1D1F; margin-bottom: 8rpx; }
.card-desc { font-size: 26rpx; color: #86868B; }
.action-hint {
  font-size: 24rpx; color: #07C160; font-weight: 500;
  margin-top: 8rpx; opacity: 0; height: 0; transition: 0.3s;
}
.action-hint.show { opacity: 1; height: auto; }

.footer { margin-top: 40rpx; margin-bottom: 20rpx; font-size: 22rpx; color: #D1D1D6; flex-shrink: 0; }

.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 999;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
}
.modal-overlay.active { opacity: 1; pointer-events: auto; }

.ios-modal {
  width: 600rpx; background: rgba(255,255,255,0.96);
  border-radius: 40rpx; padding: 48rpx; text-align: center;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.2);
  transform: scale(0.9); transition: transform 0.3s;
}
.modal-overlay.active .ios-modal { transform: scale(1); }

.modal-title { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; color: #000; }
.modal-desc { 
  font-size: 26rpx; color: #888; margin-bottom: 40rpx; 
  line-height: 1.5; /* 增加行高，多行更好看 */
}
.modal-input {
  width: 100%; height: 200rpx; background: #F2F2F2;
  border-radius: 24rpx; padding: 24rpx; font-size: 30rpx;
  text-align: left; box-sizing: border-box; margin-bottom: 40rpx;
}
.btn-group { display: flex; gap: 24rpx; }
.modal-btn {
  flex: 1; padding: 0; height: 88rpx; line-height: 88rpx;
  border-radius: 24rpx; font-size: 32rpx; font-weight: 600;
}
.modal-btn::after { border: none; }
.btn-cancel { background: #F2F2F2; color: #888; }
.btn-send { background: #007AFF; color: #fff; }

/* 成功页样式 */
.success-step {
  display: flex; flex-direction: column; align-items: center;
  animation: fadeIn 0.3s ease;
}
.success-icon { width: 100rpx; height: 100rpx; margin-bottom: 24rpx; }
.email-display {
  background: #F0F5FF; color: #007AFF;
  padding: 16rpx 32rpx; border-radius: 12rpx;
  font-size: 28rpx; font-weight: 600;
  margin-bottom: 40rpx; letter-spacing: 1rpx;
}
.btn-group.vertical { flex-direction: column; width: 100%; }
.full-width { width: 100%; }

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

/* 统一的"内容已复制"弹窗样式 - 统一和 shop 页面一样 */
.custom-modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(5px); /* 统一背景色，和 shop 页面一样 */
  z-index: 1000000001 !important; /* 🔴 修复：页面级弹窗应该高于组件级，和 my 页面一致 */
  display: flex; align-items: center; justify-content: center;
  animation: cartMaskFadeIn 0.25s ease-out forwards; /* 统一动画名称 */
}
.custom-modal-mask.closing {
  animation: cartMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; /* 统一动画名称 */
}
.custom-modal-mask.closing .custom-modal-box {
  animation: cartBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; /* 统一动画名称 */
}

.custom-modal-box {
  width: 600rpx; /* 统一宽度，和 shop 页面一样 */
  background: #ffffff;
  border-radius: 50rpx; /* 统一圆角，和 shop 页面一样 */
  padding: 70rpx 50rpx; /* 统一内边距，和 shop 页面一样 */
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15); /* 统一阴影，和 shop 页面一样 */
  animation: cartBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 统一动画名称 */
}

@keyframes cartMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes cartMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
@keyframes cartBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes cartBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
    opacity: 0;
    filter: blur(12rpx);
  }
}

.modal-icon-new {
  width: 110rpx; height: 110rpx;
  margin-bottom: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 88rpx; font-weight: 900; color: #000000; line-height: 1;
}

.modal-title-new {
  font-size: 40rpx;
  font-weight: 900;
  color: #000000;
}

/* ================= 统一的"内容已复制"弹窗 - 黑色勾，白色底，保留文字 ================= */
.copy-success-modal {
  width: 400rpx !important;
  padding: 60rpx 40rpx !important;
  min-height: auto;
  background: #ffffff !important;
}

.copy-success-modal .modal-icon-new {
  display: flex !important; /* 显示勾勾图标 */
  align-items: center;
  justify-content: center;
  width: auto;
  height: auto;
  background: transparent !important; /* 去掉黑色圆形背景 */
  border-radius: 0;
  margin: 0 auto 24rpx;
  font-size: 80rpx;
  color: #000000 !important; /* 黑色勾 */
  font-weight: 300;
  animation: checkmarkPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.copy-success-modal .modal-title-new {
  font-size: 36rpx !important;
  margin-bottom: 0 !important;
  letter-spacing: 0 !important;
  font-weight: 600 !important;
  color: #000000 !important;
  text-align: center;
  animation: toastTextPop 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

.copy-success-modal .modal-content-new {
  margin-bottom: 0 !important;
  display: none !important;
}

@keyframes checkmarkPop {
  0% {
    transform: scale(0) rotate(-45deg);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}