/* ================================================================= */
/* scan.wxss - 最终修复版 (胶囊嵌入卡片) */
/* ================================================================= */

/* --- 1. 全局基础 --- */
page {
  background-color: #eef1f5;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  overflow: hidden;
}
.container { width: 100%; height: 100%; position: relative; }

/* 顶部导航 */
.header {
  position: fixed; top: 0; left: 0; right: 0; height: 180rpx;
  padding-top: calc(env(safe-area-inset-top, 0px) + 88rpx); 
  padding-left: 40rpx; 
  padding-right: 40rpx;
  box-sizing: border-box; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  z-index: 10000; /* 🔴 提高 z-index 确保返回键显示 */
  pointer-events: none;
  background: transparent; 
}

/* 🔴 统一返回键样式 - 恢复原来的实现方式 */
/* 🔴 统一返回键样式 - 全局标准 */
.back-icon {
  position: absolute;
  left: 40rpx;
  top: calc(env(safe-area-inset-top, 0px) + 88rpx);
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

/* 统一返回箭头样式 */
.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}
.nav-logo {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #1c1c1e;
}

/* ================================================================= */
/* 2. 主卡片容器 (Integrated Card) - 父容器 */
/* ================================================================= */
.integrated-card {
  /* 距离屏幕顶部的位置 */
  margin-top: 300rpx;
  
  /* 尺寸 */
  width: 670rpx;
  height: auto;
  min-height: 70vh;
  
  /* 外观 */
  background: #FFFFFF;
  border-radius: 60rpx;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.06);
  
  /* 布局核心：相对定位，Flex 纵向排列 */
  position: relative; 
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: visible; /* 允许阴影或提示框溢出 */
  
  padding-bottom: 60rpx;
  z-index: 10;
}

/* ========================================= */
/* 2. 胶囊容器 (控制位置与跳动动画) */
/* ========================================= */
.top-capsule-wrap {
  position: relative !important;
  top: auto !important;
  left: auto !important;
  
  width: 100%;
  height: 110rpx;
  display: flex;
  justify-content: center;
  z-index: 100;
  
  /* 默认状态：稍微有一点距离 (例如 20rpx)，营造悬浮感 */
  margin-top: 50rpx; 
  
  /* 添加过渡动画，让跳动更平滑 */
  transition: margin-top 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

/* 状态：连接成功后 */
/* 胶囊容器向上移动，紧贴卡片顶部 */
.top-capsule-wrap.connected-wrapper {
  margin-top: 0rpx !important;
}

.smart-capsule {
  pointer-events: auto;
  height: 95rpx;
  border-radius: 47.5rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  
  /* 默认黑色背景 */
  background: #1C1C1E; 
  width: 320rpx; /* 默认宽度 */
  
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

/* 状态：扫描中 (变宽) */
.smart-capsule.scanning {
  width: 380rpx;
}

/* 状态：已连接 (变宽，变浅灰/白) */
.smart-capsule.connected {
  width: 660rpx; /* 撑满卡片宽度，留一点边距 */
  background: #F5F5F7; /* 浅灰色，与白色背景区分 */
}

/* --- 胶囊内部内容 --- */
.capsule-content {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  animation: fadeIn 0.3s ease-out;
}

/* A. 待机 */
.idle { gap: 14rpx; }
.idle-icon-img { width: 36rpx; height: 36rpx; animation: breathe 3s infinite ease-in-out; }
.idle text { color: #FFF; font-size: 28rpx; font-weight: 600; letter-spacing: 2rpx; }

/* B. 扫描 */
.scanning-ui { gap: 24rpx; }
.scanning-ui text { color: #CCC; font-size: 28rpx; font-weight: 600; letter-spacing: 2rpx; }

/* C. 正在连接 (白色字) */
.connecting-ui { gap: 24rpx; }

/* 连接中文字颜色 (强制白色) */
.connecting-ui text {
  color: #FFFFFF !important;
  font-size: 28rpx; 
  font-weight: 600; 
  letter-spacing: 2rpx;
}

/* D. 已连接 */
.connected-ui { justify-content: space-between; padding: 0 20rpx 0 40rpx; box-sizing: border-box; }
.status-left { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.device-name { font-size: 30rpx; font-weight: 800; color: #1c1c1e; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 扫描动画圈 */
.scan-loader { position: relative; width: 30rpx; height: 30rpx; display: flex; align-items: center; justify-content: center; }
.wave { position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 4rpx solid #FFF; opacity: 0; animation: waveAnim 1.5s infinite ease-out; }
.wave.delay { animation-delay: 0.6s; }
.blue-loader .wave { border-color: #0A84FF; } /* 蓝色波纹 */

/* ========================================= */
/* 修复：信号条动画 (强制开启) */
/* ========================================= */

/* 1. 选中信号组里的 bar，赋予动画 */
.signal-group .bar {
  width: 8rpx;
  background: #34C759; /* 绿色 */
  border-radius: 4rpx;
  /* 关键：定义动画名 signalLoop */
  animation: signalLoop 1s infinite ease-in-out !important; 
  transform-origin: bottom; /* 让它从底部向上伸缩 */
}

/* 2. 设置三根柱子的高度和延迟，形成波浪感 */
.signal-group .bar:nth-child(1) {
  height: 14rpx;
  animation-delay: 0s;
}

.signal-group .bar:nth-child(2) {
  height: 22rpx;
  animation-delay: 0.2s; /* 错开时间 */
}

.signal-group .bar:nth-child(3) {
  height: 30rpx;
  animation-delay: 0.4s; /* 错开时间 */
}

/* 3. 定义动画关键帧 (伸缩 + 透明度) */
@keyframes signalLoop {
  0%, 100% {
    transform: scaleY(1);
    opacity: 1;
  }
  50% {
    transform: scaleY(0.5); /* 缩短一半 */
    opacity: 0.5;           /* 变淡 */
  }
}

/* 信号条容器 */
.signal-group { display: flex; align-items: flex-end; gap: 6rpx; height: 30rpx; }

/* 断开按钮 */
.disconnect-btn { 
  width: 90rpx; height: 90rpx; background: #E5E5EA; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; transition: background 0.2s;
}
.disconnect-btn:active { background: #D1D1D6; }
.close-x { position: relative; width: 26rpx; height: 26rpx; }
.close-x::before, .close-x::after {
  content: ''; position: absolute; top: 10rpx; left: 0; width: 100%; height: 6rpx;
  background: #FF3B30; border-radius: 2rpx; transform: rotate(45deg);
}
.close-x::after { transform: rotate(-45deg); }

/* ========================================= */
/* 3. 提示框位置 (Toast 统一管理) */
/* ========================================= */
.toast-container {
  position: absolute;
  /* 位置固定：胶囊高度110 + 初始margin 20 + 间距20 = 150左右 */
  /* 这里设置一个固定值，确保两个弹窗出现的位置完全一样 */
  top: 200rpx; 
  left: 0; width: 100%;
  display: flex; flex-direction: column; align-items: center; gap: 20rpx;
  pointer-events: none; 
  z-index: 90;
}

.toast {
  background: rgba(255, 255, 255, 0.95); /* 稍微不透明一点，更清晰 */
  backdrop-filter: blur(12rpx);
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  display: flex; align-items: center; gap: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.12);
  
  /* 默认隐藏状态 */
  opacity: 0; 
  transform: translateY(-20rpx) scale(0.95);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  
  /* 确保不占位 (如果两个同时存在，虽然逻辑上互斥) */
  position: absolute; 
}

.toast.show {
  opacity: 1; 
  transform: translateY(0) scale(1);
  position: relative; /* 显示时占据流，或者保持absolute看重叠效果，这里建议relative让容器撑开 */
}

.toast text { color: #1D1D1F; font-size: 28rpx; font-weight: 600; letter-spacing: 1rpx; }

.t-icon {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 900; color: #fff;
}
/* 图标颜色 */
.t-icon.warn { background: #FF9500; } /* 橙色 ! */
.t-icon.err { background: #FF3B30; }  /* 红色 ! */
.t-icon.success { background: #34C759; } /* 绿色 ✓ */

/* ========================================= */
/* 7. 隐蔽模式按钮样式 */
/* ========================================= */
.stealth-btn-container {
  width: 100%;
  height: 110rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05); 
  border: 1px solid rgba(0,0,0,0.02);
  border-radius: 40rpx;
  margin-top: 30rpx; /* 与上方按钮组保持距离 */
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s;
}

.stealth-btn-container:active {
  transform: scale(0.98);
}

/* 进度条背景 */
.stealth-progress-bar {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: rgba(0, 0, 0, 0.05); /* 浅灰色进度 */
  z-index: 1;
  transition: width 0.05s linear;
}

.stealth-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  height: 100%;
}

.stealth-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1D1D1F;
}

/* 指示灯 */
.stealth-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E5E5EA; /* 默认灭 (灰) */
  border: 2rpx solid #D1D1D6;
  transition: all 0.2s;
}

/* 激活状态 (常亮) */
.stealth-indicator.active {
  background: #34C759; /* 绿灯 */
  border-color: #34C759;
  box-shadow: 0 0 10rpx rgba(52, 199, 89, 0.5);
}

/* 闪烁动画状态 (优先级高) */
.stealth-indicator.blinking {
  background: #FF3B30 !important; /* 红灯闪烁 */
  border-color: #FF3B30 !important;
  box-shadow: 0 0 16rpx rgba(255, 59, 48, 0.6);
}

/* 提示文案 */
.stealth-hint {
  position: absolute;
  right: 40rpx;
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 600;
}

.stealth-hint.success {
  color: #34C759;
}

/* ========================================= */
/* 7. 隐蔽模式入口按钮 (简约胶囊) */
/* ========================================= */
.stealth-entry-btn {
  width: 100%;
  height: 110rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.03); 
  border: 1px solid rgba(0,0,0,0.02);
  border-radius: 40rpx;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  transition: transform 0.1s;
}

.stealth-entry-btn:active {
  transform: scale(0.98);
  background: #FAFAFA;
}

.entry-icon-box {
  width: 60rpx; height: 60rpx;
  background: #F2F2F7;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx;
}

/* 一个简单的眼睛图标 CSS 画法 */
.entry-eye-icon {
  width: 24rpx; height: 16rpx;
  border: 3rpx solid #1C1C1E;
  border-radius: 50% 50% 50% 50% / 80% 80% 80% 80%;
  position: relative;
}
.entry-eye-icon::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 6rpx; height: 6rpx;
  background: #1C1C1E;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}


/* 开启模式浮动动画 */
@keyframes float-ghost-open {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 退出模式动画：突然出现 -> 等待1秒 -> 消退 -> 直接切回出现 */
@keyframes exit-ghost-animation {
  /* 0%: 消失状态 */
  0% {
    transform: translateX(0) scale(0);
    opacity: 0;
  }
  /* 0.01%: 突然出现（瞬间切换，像切图） */
  0.01% {
    transform: translateX(0) scale(1);
    opacity: 1;
  }
  /* 0.01%-50%: 保持出现状态（等待1秒） */
  50% {
    transform: translateX(0) scale(1);
    opacity: 1;
  }
  /* 50%-99.99%: 消退（持续约1秒） */
  99.99% {
    transform: translateX(0) scale(0);
    opacity: 0;
  }
  /* 100%: 消失状态（循环时直接切回0%） */
  100% {
    transform: translateX(0) scale(0);
    opacity: 0;
  }
}

/* 小幽灵图标动画 */
.ghost-icon-open {
  animation: float-ghost-open 2s ease-in-out infinite;
}

.ghost-icon-close {
  animation: exit-ghost-animation 2s linear infinite;
}

/* 上下跳动动画（折叠角度、打开角度） */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.bounce-icon {
  animation: bounce 1.5s ease-in-out infinite;
}

/* 旋转动画（自动校准、高级设置） */
@keyframes rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.rotate-icon {
  animation: rotate 3s linear infinite;
}

.entry-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1D1D1F;
  flex: 1;
}

.entry-sub {
  font-size: 24rpx;
  font-weight: 600;
  color: #8E8E93;
}

/* ================================================================= */
/* 5. 卡片内部视觉与控制区 */
/* ================================================================= */
.card-visual {
  flex: 1; width: 100%;
  display: flex; align-items: center; justify-content: center;
  background: #FFFFFF; position: relative;
}
.card-device-img {
  width: 420rpx; height: auto; 
  filter: drop-shadow(0 20rpx 40rpx rgba(0,0,0,0.05));
}

.card-controls {
  width: 100%; padding: 0 40rpx; box-sizing: border-box;
  margin-top: auto; margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center; /* 🔴 确保按钮组在容器中居中 */
}

.split-btn-group {
  width: 100%; height: 150rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05); 
  border: 1px solid rgba(0,0,0,0.02);
  border-radius: 40rpx;
  display: flex; 
  align-items: center;
  /* flex: 1 已经确保三个按钮平均分配，不需要 justify-content */
  margin-bottom: 30rpx;
}
.split-item {
  flex: 1; height: 100%;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 16rpx; transition: transform 0.1s;
}
.split-item:active { transform: scale(0.98); background: #FAFAFA; border-radius: 40rpx; }

/* F2 MAX 折叠角度页：顶部小提示条 */
.fold-inline-hint {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
  pointer-events: none; /* 只做提示，不拦截下面按钮的点击 */
}

.fold-inline-box {
  padding: 18rpx 44rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 14rpx 28rpx rgba(0,0,0,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: opacity 0.35s ease, transform 0.35s ease;
}

.fold-inline-box.show {
  opacity: 1;
  transform: translateY(0);
}

.fold-inline-box.hide {
  opacity: 0;
  transform: translateY(10rpx);
}

.fold-inline-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.fold-inline-arrow {
  font-size: 34rpx;
  color: #007AFF;
  line-height: 1;
}


/* 🔴 调整按钮滑动相关样式 */
.adjust-slider-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: visible; /* 允许滑动时超出容器 */
}

/* 底层：归零按钮（滑动后显示） */
.zero-btn-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  z-index: 1;
  background: transparent;
}

.zero-btn-layer.show {
  opacity: 1;
  pointer-events: auto;
}

/* 顶层：调整按钮（可向上滑动） */
.adjust-slider-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  z-index: 2;
  /* 默认：手动滑动时无过渡，跟手 */
  transition: none;
  touch-action: pan-y; /* 允许垂直滑动 */
  will-change: transform; /* 性能优化 */
}

/* 演示模式：自动上滑/回落时使用平滑动画 */
.adjust-slider-btn.demo {
  /* 稍微快一点的缓动，让演示看起来更顺滑、不拖沓 */
  transition: transform 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* 手动模式：松手时的回弹/归位动画（比演示更短一点） */
.adjust-slider-btn.snap {
  transition: transform 0.18s cubic-bezier(0.25, 0.8, 0.3, 1);
}

.btn-text { font-size: 28rpx; font-weight: 600; color: #1D1D1D; }
.btn-divider { width: 2rpx; height: 60rpx; background: #EEE; }
.btn-icon-circle { width: 50rpx; height: 50rpx; display: flex; align-items: center; justify-content: center; }
.svg-icon { width: 44rpx; height: 44rpx; opacity: 0.9; }

/* ================================================================= */
/* 6. 其他界面 (列表、详情、弹窗) - 保持原样 */
/* ================================================================= */
.gallery-container {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  perspective: 1000px; z-index: 10;
  transition: opacity 0.4s, transform 0.4s; pointer-events: auto;
}
.gallery-container.fade-out { opacity: 0; pointer-events: none; transform: scale(0.9); z-index: 0; }

.card {
  position: absolute; width: 620rpx; height: 1000rpx;
  background: #FFFFFF; border-radius: 60rpx; padding: 60rpx 50rpx;
  display: flex; flex-direction: column; justify-content: space-between;
  box-shadow: 0 30rpx 80rpx rgba(0,0,0,0.08);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  opacity: 0; transform: scale(0.85); z-index: 1; box-sizing: border-box;
}
.card.active { opacity: 1; z-index: 100; transform: translateX(0) scale(1); }
.card.next { opacity: 0.6; z-index: 5; transform: translateX(85%) scale(0.85); }
.card.prev { opacity: 0.6; z-index: 5; transform: translateX(-85%) scale(0.85); }
.card.hidden { opacity: 0; pointer-events: none; transform: scale(0.8); }

.card-header { text-align: left; }
.series-tag { font-size: 20rpx; font-weight: 700; color: #999; letter-spacing: 2rpx; border: 1px solid #eee; padding: 6rpx 12rpx; border-radius: 10rpx; display: inline-block; margin-bottom: 10rpx; }
.model-name { font-size: 64rpx; font-weight: 900; color: #1c1c1e; line-height: 1; }
.model-suffix { color: #007AFF; }
.model-suffix.max { color: #FF3B30; }
.model-suffix.pro-long { color: #007AFF; }
.model-suffix.max-long { color: #FF3B30; }
.visual-area { flex: 1; display: flex; align-items: center; justify-content: center; }
