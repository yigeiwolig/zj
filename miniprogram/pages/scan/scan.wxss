/* 动画关键帧定义 */
@keyframes bounceIn { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
@keyframes signalBounce { 0%, 100% { opacity: 1; transform: scaleY(1); } 50% { opacity: 0.5; transform: scaleY(0.7); } }

/* ========================================= */
/* 防误触锁定样式 */
/* ========================================= */
/* 当按钮被锁定时，透明度降低，且过渡平滑 */
.btn-locked {
  opacity: 0.3 !important; /* 变暗 */
  transition: opacity 0.3s ease-out; /* 平滑过渡 */
  pointer-events: none; /* 物理禁止点击 (双保险) */
}

/* ========================================= */
/* 最终版：从中间往左滑动 & 清理冗余代码 */
/* ========================================= */

.gesture-anim-box {
  width: 100%;
  height: 180rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
  overflow: hidden;
}

/* 1. 波轮可视区域 (Mask) */
.anim-track-mask {
  width: 100%; /* 撑满容器 */
  height: 100%;
  overflow: hidden;
  position: relative;
  /* 两侧渐变遮罩，营造滚动感 */
  mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  
  display: flex;
  align-items: center;
  justify-content: center; /* 让内部的内容居中 */
}

/* 2. 波轮移动层 (Slider) */
.track-slider {
  display: flex;
  align-items: center;
  gap: 24rpx; /* 刻度间距 */
  
  /* 初始位置：绝对居中 */
  /* 我们不需要 position absolute，flex 已经居中了，直接用 transform 做动画 */
  
  /* 绑定动画：向左移动 */
  animation: trackScrollLeft 1.8s infinite cubic-bezier(0.25, 1, 0.5, 1);
}

.track-tick {
  width: 6rpx;
  height: 30rpx;
  background: #1C1C1E;
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* 3. 手指容器 */
.anim-finger {
  position: absolute;
  top: 50%;
  left: 50%; /* 绝对居中 */
  
  /* 绑定动画：手指也向左 */
  animation: fingerSwipeLeft 1.8s infinite cubic-bezier(0.25, 1, 0.5, 1);
  pointer-events: none;
  z-index: 10;
}

/* 手指本体样式 */
.finger-dot {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 122, 255, 0.15);
  border-radius: 50%;
  border: 4rpx solid #007AFF;
  position: relative;
  box-shadow: 0 10rpx 20rpx rgba(0, 122, 255, 0.2);
}
.finger-dot::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 24rpx; height: 24rpx;
  background: #007AFF;
  transform: translate(-50%, -50%);
  border-radius: 50%;
}

/* ================== 关键帧动画 (中间 -> 左边) ================== */

/* A. 波轮刻度：向右移动 */
@keyframes trackScrollLeft {
  0% {
    transform: translateX(-60rpx); /* 起始：稍微偏左一点 */
  }
  20% {
    transform: translateX(-60rpx); 
  }
  100% {
    transform: translateX(120rpx); /* 向右移动 */
  }
}

/* B. 手指：中间 -> 右边 */
@keyframes fingerSwipeLeft {
  0% {
    transform: translate(calc(-50% - 60rpx), -50%); /* 起始：稍微偏左 */
    opacity: 0;
  }
  20% {
    opacity: 1; /* 显现 */
  }
  80% {
    opacity: 1;
    transform: translate(calc(-50% + 120rpx), -50%); /* 结束：右边 */
  }
  100% {
    transform: translate(calc(-50% + 120rpx), -50%);
    opacity: 0; /* 消失 */
  }
}

/* ========================================= */
/* 弹窗动画定义 */
/* ========================================= */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes popUp {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

