/* 添加按钮卡片 */
.add-card-btn {
  width: 100%;
  height: 120rpx;
  border: 2rpx dashed #ccc;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 20rpx;
  background: #fafafa;
}

/* 确保图文和视频卡片也有相对定位，以便删除按钮正确显示 */
.v-card,
.g-article {
  position: relative;
}

/* ================= 上传功能样式 ================= */
/* 上传卡片样式 */
.upload-box {
  width: 100%;
  height: 240rpx;
  background: #f5f5f7;
  border: 2rpx dashed #d2d2d7;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.upload-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
  font-weight: 300;
  line-height: 1;
}

.upload-box text {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

/* 渲染出的真实媒体样式 */
/* 🔴 视频包装器：用于定位全屏按钮 - 16:9比例 */
.v-player-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}

.v-player-real {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 40rpx 40rpx 0 0;
  background: #000;
}

/* 🔴 自定义全屏按钮：覆盖在视频右下角（优化样式） */
.custom-fullscreen-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  backdrop-filter: blur(10px);
  transition: all 0.2s;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.custom-fullscreen-btn:active {
  transform: scale(0.9);
  opacity: 0.7;
  background: rgba(0, 0, 0, 0.7);
}

.fullscreen-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 300;
  line-height: 1;
}

/* 🔴 全屏视频遮罩层：覆盖在整个页面上 */
.fullscreen-video-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  /* 🔴 优化：初始背景为白色，营造"白→灰→黑"的渐变效果 */
  background: #ffffff;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  /* 🔴 优化：关闭时立即开始变透明 */
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0s, 
              background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0s;
}

.fullscreen-video-mask.active {
  opacity: 1;
  pointer-events: auto;
  /* 🔴 优化：opacity立即变为1（显示白色背景），background-color延迟渐变到黑色 */
  /* 视频先飞出来，背景慢慢从白色变黑，营造流畅的视觉效果 */
  background: #000000;
  /* opacity立即显示白色背景，background-color延迟0.2s后开始渐变到黑色 */
  transition: opacity 0.1s ease-out 0s, 
              background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
}

/* 🔴 关闭状态：背景立即开始变透明，与视频缩小同步 */
.fullscreen-video-mask.closing {
  opacity: 0;
  /* 🔴 关闭时背景快速变回白色，然后变透明，时长与打开时同步（0.5s） */
  background: #ffffff;
  transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0s,
              background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0s;
}

.fullscreen-video-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
  /* 🔴 优化：默认状态，关闭时动画时间与打开时同步（0.5s） */
  transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1), opacity 0.5s ease-out;
  opacity: 0;
  will-change: transform, opacity; /* 优化性能 */
  /* 🔴 优化：添加底部内边距，让视频控制条往上移动，避免在 iPhone 上误触导航栏 */
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

/* 🔴 激活状态：从原位置放大到全屏，视频先飞出来，然后背景慢慢变黑 */
.fullscreen-video-mask.active .fullscreen-video-container.active {
  transform: translate(0, 0) scale(1) !important;
  opacity: 1;
  /* 🔴 优化：视频立即开始飞出来（0s延迟），与背景渐变同步完成 */
  transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1) 0s, 
              opacity 0.5s ease-out 0s;
}

.fullscreen-video-player {
  width: 100%;
  height: 100%;
  background: #000;
}

/* 🔴 暂停时显示的播放按钮覆盖层 */
.fullscreen-play-overlay {
  position: absolute;
