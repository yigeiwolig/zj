page { height: 100%; background: #fff; overflow: hidden; }

/* 舞台容器：这是控制跳转速度的关键 */
.stage-wrapper {
  width: 100%;
  height: 100%;
  transition: transform 1.2s cubic-bezier(0.645, 0.045, 0.355, 1); /* 高级感转场曲线 */
  will-change: transform;
}

.step-view {
  width: 100%;
  height: 100vh; /* 每一页必须占满 */
  box-sizing: border-box;
  position: relative;
}

/* 第三页需要额外的顶部间距，避开固定导航栏 */
#step3.step-view {
  padding-top: 200rpx; /* 🔴 增加顶部间距，从 180rpx 增加到 200rpx，确保有足够间隙 */
}

.view-content {
  height: 100%;       /* 确保继承全屏高度 */
  padding: 220rpx 48rpx 60rpx; /* 🔴 增加顶部间距，从 180rpx 增加到 220rpx，避免与标题遮挡 */
  display: flex;
  flex-direction: column; /* 垂直排列 */
  justify-content: center; /* 🔴 垂直居中，因为标题去掉了 */
  box-sizing: border-box;
}

/* 修改第三页专用内容包裹层 */
#step3 .view-content {
  /* 🔴 增加顶部间距，从 20rpx 增加到 40rpx，确保有足够间隙 */
  padding-top: 40rpx !important; 
}

/* 局部滚动区 */
.tutorial-scroll {
  /* 使用确定高度，避免 flex 导致全屏跳动 */
  height: calc(100vh - 180rpx - 140rpx) !important;
  width: 100%;
}

/* 顶部导航 */
.fixed-nav {
  position: fixed; top: 0; width: 100%; height: 180rpx;
  display: flex; justify-content: center; align-items: flex-end;
  padding: 0 48rpx 20rpx; z-index: 100; background: rgba(255,255,255,0.9); backdrop-filter: blur(20px);
  box-sizing: border-box;
  overflow: visible; /* 🔴 确保按钮不被裁剪 */
}

/* 顶部导航 */
.header {
  position: fixed; top: 0; left: 0; right: 0; height: 180rpx;
  padding-top: calc(env(safe-area-inset-top, 0px) + 88rpx); 
  padding-left: 40rpx; 
  padding-right: 40rpx;
  box-sizing: border-box; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  z-index: 100; 
  pointer-events: none;
  background: transparent; 
}

/* 🔴 统一返回键样式 - 全局标准 */
.back-icon {
  position: fixed;
  left: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

/* 统一返回箭头样式 */
.back-arrow {
  font-size: 48rpx;
  font-weight: 600;
  color: #000;
  line-height: 1;
}

/* 返回键 - 统一样式（兼容 back-btn 类名） */
.back-btn {
  position: fixed;
  left: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10001;
  pointer-events: auto;
  transition: all 0.2s;
}

/* 返回键内的文本样式 */
.back-btn .back-icon {
  font-size: 48rpx;
  font-weight: 600;
  color: #000;
  line-height: 1;
}

.back-btn:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}

/* 品牌区 */
.brand {
  display: flex;
  flex-direction: column; /* 🔴 改为垂直布局 */
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
  min-height: 60rpx;
  overflow: visible;
}

.brand-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.brand text {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #000;
}

/* 🔴 优化：管理员开关按钮 - 显示在标题下方 */
.admin-toggle-btn {
  margin-top: 12rpx; /* 🔴 标题和按钮之间的间距 */
  font-size: 20rpx;
  color: #999;
  border: 1rpx solid #e0e0e0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
  font-weight: 600;
  letter-spacing: 1rpx;
  white-space: nowrap;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  display: block;
  visibility: visible;
  opacity: 1;
  min-width: 80rpx;
  min-height: 40rpx;
}

/* 开启状态的颜色 */
.admin-toggle-btn.on {
  background: #000;
  color: #fff;
  border-color: #000;
}

.step-indicator { 
  position: absolute;
  right: 48rpx;
  bottom: 30rpx;
  font-size: 18rpx; 
  font-weight: 700; 
  color: #999; 
}

/* 卡片样式（继承之前的圆角与质感） */
.p-card {
  position: relative; /* 必须！否则绝对定位的 Logo 会跳出卡片 */
  overflow: hidden;   /* 裁剪溢出的水印部分，形成水印切边效果 */
  flex: 1;            /* 关键：三个型号卡片自动平分第一屏高度 */
  background: #f5f5f7; 
  border-radius: 50rpx; 
  padding-left: 30rpx !important; /* 文字再稍微往左一点 */
  padding-right: 60rpx !important;
  display: flex; 
  flex-direction: column !important; /* 确保使用列方向 */
  justify-content: center !important; /* 垂直方向：居中 */
  align-items: flex-start !important; /* 水平方向：靠左 */
  border: 1rpx solid #efefef; 
  transition: all 0.4s; 
  margin-bottom: 24rpx;
  height: auto; /* 确保文字不会因为系列名去掉后留下空隙 */
}
/* 第一步（产品卡片）选中态 —— 纯黑沉浸 */
.p-card.active {
  background: #000000 !important;
  color: #ffffff !important;
  transform: scale(1.02);
  box-shadow: 0 30rpx 60rpx rgba(0,0,0,0.1);
}

/* MT Logo：极致淡化 */
.mt-logo {
  position: absolute !important;
  right: 40rpx !important; /* 完美的垂直居中公式 */
  top: 50% !important;
  transform: translateY(-50%) !important; /* 完美的垂直居中公式 */
  font-size: 140rpx !important; /* 保持之前的尺寸 */
  font-weight: 900 !important;
  font-style: italic !important;
  line-height: 1 !important;
  pointer-events: none;
  z-index: 1;
  /* 初始颜色：极淡 */
  color: rgba(0, 0, 0, 0.02) !important;
  transition: all 0.4s ease;
}

/* 第二步选中时，Logo 颜色微调，与第一页的白水印区分开 */
.t-card.active .mt-logo {
  color: rgba(0, 0, 0, 0.04) !important; /* 从 0.02 调到 0.04，让 Logo 也稍微明显一点 */
}

/* --- 第一页：产品型号卡片颜色 --- */
/* 未选中：浅灰卡片 + 极淡黑水印 */
.p-card .mt-logo { color: rgba(0, 0, 0, 0.03); }
/* 选中：黑卡 + 明显可见的白水印 */
.p-card.active .mt-logo {
  color: rgba(255, 255, 255, 0.15) !important; /* 透明度从 0.05 提升到 0.15，确保能看清但又不扎眼 */
  font-style: italic !important; /* 保持倾斜和位置 */
}


/* 第二步卡片：默认状态（极简、浅淡） */
.t-card {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: #F8F8F8 !important; /* 非常浅的灰色 */
  border-radius: 40rpx;
  display: flex;
  flex-direction: column !important; /* 确保使用列方向 */
  justify-content: center !important; /* 垂直方向：居中 */
  align-items: flex-start !important; /* 水平方向：靠左 */
  padding-left: 30rpx !important; /* 文字再稍微往左一点 */
  padding-right: 60rpx !important;
  /* 初始边框设为透明，但保留宽度，防止选中时闪烁 */
  border: 6rpx solid transparent; 
  transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.2); 
}

/* 第二步卡片：选中状态（极致黑框白底，制造视觉差） */
.t-card.active {
  background: #FFFFFF !important;  /* 变纯白 */
  border-color: #000000 !important; /* 极粗的黑色边框 */
  transform: scale(1.04);           /* 明显的放大回弹 */
  box-shadow: 0 30rpx 60rpx rgba(0,0,0,0.08); /* 增加柔和阴影 */
}

/* 车型文字：选中后变粗 */
.t-name {
  text-align: left !important;
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a1a;
  transition: all 0.3s ease;
  line-height: 1.2;
  display: block;
  z-index: 2;
}

.t-card.active .t-name {
  font-weight: 900; /* 选中后文字更有分量 */
  transform: translateX(10rpx); /* 轻微右移，产生交互感 */
}

/* 头部样式 */
.header-group {
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.main-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #666;
  letter-spacing: -1rpx;
  display: inline-block;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid #ccc;
}

/* 产品卡片信息 */
.p-info {
  position: relative;
  margin: 0 !important; /* 确保没有任何外边距 */
  padding: 0 !important;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start !important; /* 强制内部文字靠左 */
  text-align: left !important;
}

.p-name {
  text-align: left !important;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.2;
  display: block;
}

/* 隐藏不再需要的样式类 */
.tag,
.p-series,
.p-suffix,
.v-num,
.step-indicator {
  display: none !important;
}

/* 卡片堆叠 */
.card-stack { flex: 1; display: flex; flex-direction: column; gap: 20rpx; }

/* 车型选择容器 */
.type-stack {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx; /* 增加间距，让卡片呼吸感更强 */
}


/* 优化切换器的样式 (Mode Switch) */
.mode-switch {
  display: flex;
  background: #f0f0f2;
  padding: 8rpx;
  border-radius: 20rpx; /* 圆角稍微收小一点，显精致 */
  margin-bottom: 60rpx; /* 增加下方与内容的间距 */
  
  /* 限制最大宽度并居中，不要撑满全屏，这样更高级 */
  width: 85%;
  margin-left: auto;
  margin-right: auto;
  position: relative;
  z-index: 10; /* 确保切换器在固定导航栏之上 */
}

/* 切换器紧贴标题栏下方，只留一点点间距 */
#step3 .mode-switch {
  margin-top: 0 !important; /* 移除额外间距，让它紧贴标题栏 */
}

.m-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0; /* 缩小上下内边距，让按钮变扁一点，更像胶囊 */
  font-size: 24rpx; /* 字体稍微调小 2rpx */
  font-weight: 700;
  color: #999;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.m-btn.active {
  background: #fff;
  color: #000;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

/* 显示全部开关 */
.show-all-switch {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 24rpx;
  background: #f0f0f2;
  border-radius: 12rpx;
  text-align: center;
}

.show-all-text {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 600;
}

/* 教程展示块 (V-Card) */
.v-card { background: #fff; border-radius: 50rpx; overflow: hidden; margin-bottom: 40rpx; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.05); }
.v-player { 
  width: 100%; 
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  background: #000; 
  position: relative;
  display: flex; 
  justify-content: center; 
  align-items: center; 
}
.v-player video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.play-btn { width: 80rpx; height: 80rpx; background: rgba(255,255,255,0.2); border-radius: 50%; color: #fff; display: flex; justify-content: center; align-items: center; font-size: 40rpx; }
.v-info { padding: 40rpx; }
.v-title { font-size: 32rpx; font-weight: 700; display: block; }

/* 图文块 */
.g-article { margin-bottom: 60rpx; }
.g-media { 
  width: 100%; 
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  background: #f5f5f7; 
  border-radius: 40rpx; 
  margin-bottom: 30rpx; 
  position: relative;
  overflow: hidden;
}
.g-media image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.g-info { padding: 0 10rpx; }
.g-title { font-size: 40rpx; font-weight: 800; display: block; margin-bottom: 15rpx; }
.g-desc { font-size: 28rpx; color: #666; line-height: 1.6; }

/* ================= 椭圆密码弹窗样式 ================= */
.pwd-modal {
