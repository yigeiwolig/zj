/* ================= 本页自定义加载动画（白色虚化 + 你的 loader，同 my 页） ================= */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loader {
  width: 600rpx;
  height: 260rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-evenly;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
  box-sizing: border-box;
}

.loading-bar {
  width: 100%;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.loading-bar::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: #1c1c1e;
  border-radius: 20rpx;
  z-index: 1;
  animation: loadingBar 0.6s alternate infinite ease-in-out;
}

.loader-label {
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 700;
  animation: labelBlink 0.6s alternate infinite;
}

@keyframes labelBlink {
  from { opacity: 0.35; }
  to   { opacity: 1; }
}

@keyframes loadingBar {
  0%   { left: 0%; }
  50%  { left: 25%; }
  100% { left: 50%; }
}

/* 全局样式 */
page {
  background-color: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  box-sizing: border-box;
  /* 🔴 核心修复：禁用整个页面滚动，禁止回弹 */
  overflow: hidden;
  height: 100vh;
}

/* 0. 背景大水印 */
.brand-bg-watermark {
  position: fixed;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-30deg);
  font-size: 100rpx;
  font-weight: 900;
  color: rgba(0, 0, 0, 0.03);
  pointer-events: none;
  z-index: -1;
  white-space: nowrap;
}

/* 1. 顶部大标题 */
.custom-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background-color: rgba(242, 242, 247, 0.95);
  backdrop-filter: blur(20px);
  padding-bottom: 10px;
}

.header-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
