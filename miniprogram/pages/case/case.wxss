/* 🔴 新增：iOS 风格自定义选择器样式（用于模拟器） */
.custom-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8rpx);
  z-index: 10001; /* 🔴 确保在 modal-overlay (2000) 之上 */
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.custom-picker-content {
  width: 100%;
  background: #F2F2F7;
  border-radius: 40rpx 40rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #F2F2F7;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  position: relative;
}

.picker-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(0, 0, 0, 0.1), transparent);
}

.picker-cancel,
.picker-confirm {
  font-size: 34rpx;
  color: #007AFF;
  padding: 12rpx 24rpx;
  font-weight: 500;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.picker-cancel:active,
.picker-confirm:active {
  background: rgba(0, 122, 255, 0.1);
}

.picker-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
  letter-spacing: -0.5rpx;
}

.picker-view {
  height: 360rpx;
  width: 100%;
  background: #fff;
  position: relative;
}

/* 顶部和底部渐变遮罩 */
.picker-view::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0));
  pointer-events: none;
  z-index: 2;
}

.picker-view::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0));
  pointer-events: none;
  z-index: 2;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  font-size: 34rpx;
  color: #000;
  font-weight: 400;
  transition: all 0.2s;
  position: relative;
}

/* 选中项指示器 - 使用额外的元素 */
.custom-picker-content::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 72rpx;
  transform: translateY(-50%);
  margin-top: 120rpx; /* 调整位置，避开 header */
  background: rgba(0, 122, 255, 0.06);
  border-top: 1rpx solid rgba(0, 122, 255, 0.2);
  border-bottom: 1rpx solid rgba(0, 122, 255, 0.2);
  pointer-events: none;
  z-index: 1;
}

.dialog-btn {
  background: #000;
  color: #fff;
  width: 100% !important;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 32rpx;
