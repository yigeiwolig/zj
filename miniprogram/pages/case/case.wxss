/* 🆕 新的发布按钮 (黑底，更像上传/发布) */
.publish-btn {
  width: 130rpx !important;
  height: 130rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 50% !important;
  
  /* 🔴 改为黑色背景，显高级，代表"创作/发布" */
  background: #000000; 
  
  display: flex;
  align-items: center;
  justify-content: center;
  
  /* 增加投影，让它浮起来 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  border: 4rpx solid #ffffff; /* 加个白边，更有层次感 */
}

.publish-btn:active {
  transform: scale(0.95); /* 点击时的按压效果 */
  opacity: 0.9;
  /* 🔴 优化：使用 will-change 提升动画性能 */
  will-change: transform;
}

/* 🆕 纯 CSS 绘制的白色加号 (+) */
.icon-plus {
  position: relative;
  width: 50rpx;
  height: 50rpx;
}

.icon-plus::before,
.icon-plus::after {
  content: '';
  position: absolute;
  background-color: #ffffff; /* 白色加号 */
  border-radius: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 横线 */
.icon-plus::before {
  width: 50rpx;
  height: 6rpx;
}

/* 竖线 */
.icon-plus::after {
  width: 6rpx;
  height: 50rpx;
}

/* 5. 弹窗系统 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s;
}

.modal-overlay.active {
  opacity: 1;
  visibility: visible;
}

.ios-dialog {
  position: relative; 
  background: #FFFFFF;
  width: 600rpx;
  border-radius: 48rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  transform: scale(0.95);
  transition: transform 0.3s;
}

/* 🔴 新增：抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0) scale(0.95); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx) scale(0.95); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx) scale(0.95); }
}

.ios-dialog.shake {
  animation: shake 0.3s ease-in-out;
}

.modal-overlay.active .ios-dialog {
  transform: scale(1);
}

