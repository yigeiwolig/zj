/* 🆕 录制页面 UI 升级 (高级版) */
/* =========================== */

/* 1. 顶部时间：纯白 + 红色呼吸点 */
.rec-header-layout {
  position: absolute;
  top: 120rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx; /* 点和字的间距 */
  opacity: 0.9;
}

/* 那个红点 */
.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #FF3B30;
  opacity: 0; /* 默认隐藏 */
  transition: opacity 0.15s; /* 🔴 优化：缩短到 0.15s，与摄像头同步 */
}

/* 录制时，红点闪烁 */
.rec-dot.active {
  opacity: 1;
  animation: blinkDot 1s infinite;
}

@keyframes blinkDot {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

/* 时间文字：白色、高级字体 */
.rec-time-text {
  color: #FFFFFF; /* 🔴 改回白色，不显low */
  font-size: 48rpx; /* 不需要巨大，精致一点 */
  font-weight: 500;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', Roboto, sans-serif;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); /* 淡淡的投影保证清晰度 */
}

/* 2. 隐私提示：白色背景清晰可见 */
.privacy-tip {
  position: absolute;
  top: 30%; /* 稍微往上放一点，不遮挡视线 */
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  
  /* 🔴 核心：白色背景，清晰可见 */
  background: #FFFFFF; /* 纯白背景 */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15); /* 添加阴影增加层次感 */
  
  padding: 24rpx 40rpx;
  border-radius: 60rpx; /* 胶囊形状 */
  
  display: flex;
  align-items: center;
  justify-content: center;
  
  opacity: 0;
  transition: all 0.2s ease-out; /* 🔴 优化：从 0.6s 缩短到 0.2s，快速退场 */
  pointer-events: none;
}

.privacy-tip.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.privacy-text {
  color: #333333; /* 深色文字，在白色背景上清晰可见 */
  font-size: 28rpx;
  font-weight: 500; /* 稍微加粗，更清晰 */
  letter-spacing: 1rpx;
  text-align: center;
  line-height: 1.5;
}

.cam-controls {
  position: absolute; bottom: 0; left: 0; width: 100%; height: 240rpx;
  background: rgba(0,0,0,0.5);
