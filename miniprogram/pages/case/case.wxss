/* 1. 修复 Tab 被遮挡的问题 */
.nav-container {
  position: fixed;
  left: 0;
  width: 100%;
  z-index: 49;
  background-color: #F2F2F7;
  /* 🔴 修改：增加顶部内边距，把 Tab 往下挤一点，就不会被标题栏挡住了 */
  padding-top: 20rpx; 
  padding-bottom: 10rpx;
}

/* Tab 滚动区域 */
.scroll-wrapper {
  width: 100%;
  white-space: nowrap;
  position: relative;
  z-index: 10; /* 保证 Tab 在搜索条上面 */
}

.tab-list {
  display: flex;
  padding: 0 32rpx;
  position: relative; /* 为滑块定位 */
  height: 80rpx;
  align-items: center;
}

/* 🆕 黑色滑块 */
.tab-slider {
  position: absolute;
  top: 10rpx;
  height: 60rpx;
  background: #000000;
  border-radius: 30rpx;
  z-index: 1; 
  transition: left 0.3s cubic-bezier(0.25, 1, 0.5, 1), 
              width 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  /* 关键：给个下阴影遮丑 */
  box-shadow: 0 4rpx 0 #000;
}

/* 文字按钮 */
.tab-item {
  display: inline-block;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #8E8E93;
  margin-right: 20rpx;
  position: relative;
  z-index: 2;
  transition: color 0.3s;
  
  /* 🔴 核心修复：强制文字不换行，保证宽度计算准确 */
  white-space: nowrap; 
}

.tab-item.active {
  color: #FFFFFF; /* 选中变白 */
  font-weight: 600;
}

/* 🆕 列表飞入动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.move-animation {
  /* 每次渲染都触发简单的上浮动画 */
  animation: fadeInUp 0.5s ease-out forwards;
}

/* 🔴 核心修改：定义 scroll-view 样式 */
.main-scroll-view {
  width: 100%;
  position: fixed;
  left: 0;
  z-index: 1;
  background-color: #F2F2F7;
}

/* 2. 把列表内容往下推，解决顶部被遮挡的问题 */
/* 列表容器 */
.video-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  position: relative;
  z-index: 1;
  /* 默认状态 (搜索框收起时)：Nav高(80) + 间距 */
  padding-top: 20rpx; 
  /* 关键：增加过渡动画，让列表滑上滑下 */
  transition: padding-top 0.3s cubic-bezier(0.25, 1, 0.5, 1);
}

/* 🔴 核心修复：当搜索框出来时，列表自动往下移 */
.video-list.pushed-down {
  /* 展开状态：默认(20) + 搜索框高(120) */
  padding-top: 140rpx; 
}

