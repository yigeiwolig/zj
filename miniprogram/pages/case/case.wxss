}

/* 顶部导航 */
.header {
  position: fixed; top: 0; left: 0; right: 0; height: 180rpx;
  padding-top: calc(env(safe-area-inset-top, 0px) + 88rpx); 
  padding-left: 40rpx; 
  padding-right: 40rpx;
  box-sizing: border-box; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  z-index: 10000; /* 🔴 提高 z-index 确保返回键显示 */
  pointer-events: none;
  background: transparent; 
}

/* 🔴 统一返回键样式 - 全局标准 */
.back-icon {
  position: absolute;
  left: 40rpx;
  top: calc(env(safe-area-inset-top, 0px) + 88rpx);
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

/* 统一返回箭头样式 */
