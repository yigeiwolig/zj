/* 6. 全屏相机 */
.camera-full-screen {
  position: fixed; 
  top: 0; 
  left: 0; 
  width: 100vw; 
  height: 100vh; 
  z-index: 3000; 
  background: #000;
  /* 🔴 禁用页面滑动 */
  touch-action: none;
  overflow: hidden;
  /* 🔴 优化：使用 GPU 加速，提升动画性能 */
  will-change: transform, opacity, border-radius;
  transform: translateZ(0);
  
  /* 🆕 关键：transform-origin 设置在底部中心（按钮位置） */
  /* 按钮位置：bottom: 60rpx, 按钮高度130rpx，中心在底部往上 125rpx */
  /* 使用 center bottom 让缩放从底部中心开始 */
  transform-origin: center bottom;
  transform: scale(0.05); /* 🆕 初始很小，从按钮大小开始 */
  opacity: 0;
  border-radius: 50%; /* 🆕 初始圆形，模拟从圆形按钮弹出 */
  /* 🔴 优化：使用更高效的动画属性，减少重绘 */
  /* 🔴 优化：缩短退场动画时间，提升响应速度 */
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
              opacity 0.2s ease-out,
              border-radius 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 🆕 动画进行中：保持初始状态（从按钮位置，很小，圆形） */
.camera-full-screen.animating {
  transform: scale(0.05);
  opacity: 0;
  border-radius: 50%;
}

/* 🆕 动画完成：从按钮位置直接放大到全屏，带弹性弹跳效果 */
.camera-full-screen.animated {
  transform: scale(1); /* 🆕 放大到全屏，从底部中心展开 */
  opacity: 1;
  border-radius: 0; /* 变成全屏矩形 */
}
.cam-overlay {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  pointer-events: none;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
}
