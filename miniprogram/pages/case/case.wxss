  padding-bottom: 40rpx;
  z-index: 9999;
}
.cam-btn { color: #fff; font-size: 32rpx; }

/* 3. 按钮丝滑变形与呼吸动画 */

/* 外圈 (保持不动) */
.shutter-outer {
  width: 150rpx;
  height: 150rpx;
  border: 8rpx solid rgba(255, 255, 255, 1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}
/* 点击时的按压感 */
.shutter-outer:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 内核 (红色部分) */
.shutter-inner {
  width: 120rpx;  /* 初始圆大小 */
  height: 120rpx;
  background: #FF3B30;
  border-radius: 60rpx; /* 🔴 改为固定值，与宽高的一半一致，确保过渡平滑 */
  
  /* 🔴 核心：分别设置过渡，让圆角变化和尺寸变化同步进行 */
  /* 🔴 优化：缩短动画时间，退场时更快 */
  transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1),
              height 0.2s cubic-bezier(0.4, 0, 0.2, 1),
              border-radius 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 录制状态：变成圆角方块 */
.shutter-inner.recording {
  width: 60rpx;   /* 变小 */
  height: 60rpx;
  border-radius: 12rpx; /* 变成圆角矩形 */
  background: #FF3B30;
}

/* 🆕 呼吸动画定义 */
@keyframes breathe {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(0.8); /* 缩小一点 */
    opacity: 0.7;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 当同时拥有 recording 和 breathing 类时触发动画 */
.shutter-inner.breathing {
  animation: breathe 1.5s infinite ease-in-out;
}

