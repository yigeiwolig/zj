.cr-info { flex: 1; }
.cr-name { font-size: 28rpx; font-weight: 600; margin-bottom: 8rpx; }
.cr-spec { font-size: 24rpx; color: #86868B; }
.cr-action { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
