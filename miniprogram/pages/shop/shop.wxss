/* pages/shop/shop.wxss */
page {
  background-color: #F5F5F7;
  color: #1D1D1F;
  font-family: -apple-system, "SF Pro Display", sans-serif;
  height: 100%;
  overflow: hidden; 
}

/* ================= 本页自定义加载动画（白色虚化 + 你的 loader） ================= */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loader {
  width: 600rpx;
  height: 260rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-evenly;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
  box-sizing: border-box;
}

.loading-bar {
  width: 100%;
  height: 20rpx;
  background: #E5E5EA;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.loading-bar::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: #1c1c1e;
  border-radius: 20rpx;
  z-index: 1;
  animation: loadingBar 0.6s alternate infinite ease-in-out;
}

.loader-label {
  color: #1c1c1e;
  font-size: 28rpx;
  font-weight: 700;
  animation: labelBlink 0.6s alternate infinite;
}

@keyframes labelBlink {
  from { opacity: 0.35; }
  to   { opacity: 1; }
}

@keyframes loadingBar {
  0%   { left: 0%; }
  50%  { left: 25%; }
  100% { left: 50%; }
}

/* ============ 通用组件 ============ */
.btn-black {
  background: #000; color: #fff; font-weight: 600; padding: 30rpx 40rpx;
  border-radius: 60rpx; font-size: 30rpx; text-align: center;
}
.btn-black.full { width: 100%; box-sizing: border-box; }
.editable { 
  border-bottom: 2rpx dashed #999; 
  display: inline-block; 
  min-width: 40rpx; 
  cursor: pointer;
  transition: all 0.2s ease;
}

/* 顶部导航 */
.header {
  position: fixed; top: 0; left: 0; right: 0;
  padding-left: 40rpx; padding-right: 40rpx;
  box-sizing: border-box; display: flex; justify-content: space-between; align-items: center;
  z-index: 10000; pointer-events: none; /* 🔴 提高 z-index 确保返回键显示 */
  background: transparent; 
}
/* 🔴 统一返回键样式 - 全局标准（使用计算值） */
.back-icon {
  position: absolute;
  left: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s;
  z-index: 10001;
}
.back-icon:active {
  transform: scale(0.95);
  opacity: 0.7;
  background-color: rgba(0, 0, 0, 0.05);
}
.back-icon::before {
  display: none;
}

/* 统一返回箭头样式 */
.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}

/* ============ 1. 顶部导航 ============ */
.nav-header {
  position: absolute; top: 0; left: 0; width: 100%;
  display: flex; align-items: center; justify-content: space-between; /* 🔴 改为 center，让标题垂直居中 */
  padding: 0 40rpx; box-sizing: border-box;
  background: rgba(245,245,247,0.9); backdrop-filter: blur(20px); z-index: 100;
}
.nav-left {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
/* 统一返回按钮样式 - 与 azjc 页面一致 */
.nav-back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}

.nav-back-btn:active {
  transform: scale(0.95);
  opacity: 0.7;
}

.icon-back {
  font-size: 48rpx;
  font-weight: 300;
  color: #000;
  line-height: 1;
}
.brand-title { 
  position: absolute;
  left: 50%;
  transform: translateX(-50%) translateY(-50%); /* 🔴 添加 translateY(-50%) 实现垂直居中 */
  font-size: 38rpx; 
  font-weight: 800; 
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  pointer-events: auto;
}

/* 管理员切换按钮 */
.admin-toggle-btn {
  display: inline-block;
  margin-left: 20rpx;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  color: #8E8E93;
  border: 1rpx solid #E5E5EA;
  vertical-align: middle;
  transition: all 0.3s;
  font-weight: 600;
}

/* 开启状态的颜色 */
.admin-toggle-btn.on {
  background: #000;
  color: #fff;
  border-color: #000;
}

.admin-badge { background: #000; color: #fff; font-size: 18rpx; padding: 6rpx 10rpx; border-radius: 8rpx; }

/* ============ 2. 主页面 ============ */
.main-scroll { height: 100vh; padding-top: 180rpx; box-sizing: border-box; }

/* Hero 轮播 - 16:9比例 */
.hero-swiper-box { 
  width: 100%; 
  padding-bottom: 56.25%; /* 16:9 比例 (9/16 = 0.5625) */
  background: #000; 
  position: relative; 
  margin-bottom: 40rpx; 
  height: 0;
}
.hero-swiper { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
}
.hero-media { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
  object-fit: cover; 
}
/* 🔴 新增：详情页视频管理员控制开关组 */
.admin-detail-video-controls {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 30;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.video-control-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 200rpx;
}

.control-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  margin-right: 20rpx;
}

/* iOS风格开关 */
.switch-toggle {
  width: 88rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 26rpx;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.switch-toggle.on {
  background: #34C759;
}

.switch-thumb {
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.switch-toggle.on .switch-thumb {
  transform: translateX(36rpx);
}

.switch-toggle:active {
  opacity: 0.8;
}

/* 🔴 新增：拖拽排序列表 */
.media-drag-list {
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx;
  /* 🔴 使用动态计算高度 */
  max-height: calc(100vh - 200px);
  overflow-y: auto;
}

.drag-tip {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f5f5f7;
  border-radius: 12rpx;
}

.drag-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.2s;
}

.drag-item:active {
  background: #f0f0f0;
  border-color: #0071E3;
}

.drag-item-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #000;
  margin-right: 20rpx;
  position: relative;
}

.drag-preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.drag-preview-video {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.drag-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.drag-item-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

.drag-item-badges {
  display: flex;
  gap: 10rpx;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.pin-badge {
  background: #FFC107;
}

.autoplay-badge {
  background: #4CAF50;
}

.drag-handle {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.drag-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #e0e0e0;
}

.drag-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.drag-btn.cancel {
  background: #f5f5f7;
  color: #666;
}

.drag-btn.confirm {
  background: #000;
  color: #fff;
}

.drag-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* Admin: 左右分开的上传按钮 */
.admin-upload-row {
  position: absolute; bottom: 30rpx; right: 30rpx;
  display: flex; gap: 20rpx; z-index: 20;
}
.up-btn {
  background: rgba(255,255,255,0.95); color: #000;
  padding: 12rpx 24rpx; border-radius: 40rpx;
  font-size: 24rpx; font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
}

/* 产品列表 (单列大卡片) */
.product-list { padding: 0 30rpx; display: flex; flex-direction: column; gap: 40rpx; }
.prod-card {
  background: #fff; border-radius: 30rpx; overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05); position: relative;
  transition: 0.2s;
}
.prod-card:active { transform: scale(0.98); }
.product-cover-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  overflow: hidden;
}
.p-img { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
  object-fit: cover; 
}
.p-info { padding: 40rpx; }
.p-row { display: flex; justify-content: space-between; font-weight: 700; font-size: 34rpx; align-items: center; }
.p-price-wrapper { 
  padding: 8rpx 16rpx; 
  border-radius: 8rpx; 
  transition: all 0.2s;
}
.p-price-wrapper.editable {
  background: rgba(0, 113, 227, 0.08);
  border: 2rpx dashed rgba(0, 113, 227, 0.3);
}
.p-price-wrapper.editable:active {
  background: rgba(0, 113, 227, 0.15);
  transform: scale(0.98);
}
.p-price { 
  font-weight: 700; 
  font-size: 34rpx; 
  color: #000;
}
.add-series-btn { text-align: center; padding: 60rpx; border: 4rpx dashed #ccc; border-radius: 30rpx; color: #999; font-weight: 600; }
/* 2. 移动相机图标（上传封面）到右下角，避免和删除按钮打架 */
.admin-float {
  position: absolute !important;
  top: auto !important;     /* 取消原本的 top */
  bottom: 20rpx !important; /* 改到下面 */
  right: 20rpx !important;
  
  width: 70rpx; 
  height: 70rpx; 
  background: rgba(255,255,255,0.8) !important; /* 改为半透明白底 */
  backdrop-filter: blur(10px);
  color: #000 !important;     /* 黑相机 */
  border-radius: 50%; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-size: 32rpx; 
  z-index: 25; 
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
/* 跳转号码标识 */
.jump-number-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  z-index: 20;
  pointer-events: auto;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

/* ============ 3. 产品详情全屏弹窗 ============ */
.full-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #fff; z-index: 200; display: flex; flex-direction: column; transform: translateY(100%); transition: 0.4s cubic-bezier(0.19, 1, 0.22, 1); }
.full-modal.active { transform: translateY(0); }
.modal-nav { height: 180rpx; padding: 0 30rpx 20rpx; display: flex; align-items: flex-end; justify-content: space-between; border-bottom: 1rpx solid #eee; flex-shrink: 0; }
.nav-close { 
  font-size: 44rpx; 
  padding: 20rpx; 
  color: #888; 
  z-index: 10001;
  position: relative;
  pointer-events: auto;
  min-width: 64rpx;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-title { font-weight: 700; font-size: 32rpx; }

.modal-scroll { 
  flex: 1; 
  min-height: 0; /* 🔴 关键：允许 flex 子元素缩小 */
  overflow-y: scroll; 
  background: #fff; 
  position: relative; 
  z-index: 1; 
  -webkit-overflow-scrolling: touch; /* 🔴 iOS 平滑滚动 */
}
.scroll-inner { padding-bottom: 50rpx; }
/* 确保 scroll-view 不会覆盖底部按钮 */
.modal-scroll {
  padding-bottom: 0;
  margin-bottom: 0;
}
.detail-images { margin-bottom: 40rpx; }
.dimg-box { 
  position: relative; 
  width: 100%; 
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  overflow: hidden;
  transition: transform 0.3s ease-out, box-shadow 0.2s, opacity 0.2s;
}

.dimg-box.dragging {
  transition: none !important;
  transform: translateZ(0) scale(1.02);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
  z-index: 100;
  opacity: 0.95;
  border: 2rpx solid #007AFF;
  will-change: transform;
}
.dimg { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
  display: block; 
  object-fit: cover; 
}
.admin-del-abs { position: absolute; top: 20rpx; right: 20rpx; background: red; color: #fff; width: 50rpx; height: 50rpx; border-radius: 50%; text-align: center; line-height: 50rpx; }
.add-txt-btn { text-align: center; padding: 40rpx; color: #0071E3; font-weight: 600; font-size: 26rpx; }

/* 选购配置 Header */
.config-sec { padding: 0 40rpx; }
.sec-header-row { display: flex; justify-content: space-between; align-items: center; margin: 60rpx 0 30rpx; }
.sec-title { font-size: 36rpx; font-weight: 800; margin: 0; color: #1D1D1F; }
/* 修改 2：参数对比按钮改成纯黑色，简约风格 */
.btn-compare {
  background: #000000;  /* 纯黑背景 */
  color: #ffffff;       /* 白色文字 */
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
}
.cfg-group { margin-bottom: 60rpx; }
.cfg-label { font-size: 28rpx; color: #1D1D1F; font-weight: 700; margin-bottom: 24rpx; }

/* 型号列表 */
.model-item { padding: 30rpx; border: 2rpx solid #eee; border-radius: 16rpx; margin-bottom: 20rpx; display: flex; justify-content: space-between; align-items: center; position: relative; }
.model-item.selected { border-color: #0071E3; background: rgba(0,113,227,0.03); }
.m-name { font-weight: 700; font-size: 32rpx; color: #1D1D1F; }
.m-desc { font-size: 26rpx; color: #666; display: block; margin-top: 8rpx; }
.m-price { font-weight: 700; font-size: 32rpx; color: #1D1D1F; }
/* 修改 1：加大管理员删除按钮的间距，防止点错 */
.admin-del-mini {
  position: absolute;
  top: 0;           /* 贴顶 */
  right: 0;         /* 贴右 */
  padding: 20rpx;   /* 增加点击范围（关键）*/
  color: red;
  font-size: 28rpx;
  z-index: 10;      /* 确保在最上层 */
  font-weight: bold;
}

/* 选项 Grid (图上字下) */
.opt-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.opt-card { width: 30%; flex-grow: 1; border: 2rpx solid #eee; border-radius: 16rpx; position: relative; overflow: hidden; display: flex; flex-direction: column; align-items: center; text-align: center; transition: all 0.3s ease; }
.opt-card.selected { 
  border: 4rpx solid #0071E3; /* 🔴 和型号选择保持一致，使用4rpx边框 */
  background: #F2F7FF; /* 🔴 和型号选择保持一致，使用相同的背景色 */
  box-shadow: 0 8rpx 20rpx rgba(0, 113, 227, 0.15); /* 🔴 和型号选择保持一致，使用相同的阴影 */
  transform: scale(1.02); /* 🔴 和型号选择保持一致，使用相同的放大效果 */
}

/* 🔴 优化：管理员模式下改为横向布局，左边文字，右边上传照片 */
.opt-grid.admin-mode .opt-card.admin-mode {
  width: 100% !important; /* 横向拉长，占满整行 */
  flex-direction: row !important; /* 改为横向布局 */
  align-items: center !important;
  text-align: left !important; /* 文字左对齐 */
  padding: 30rpx !important;
  min-height: 180rpx !important;
  gap: 30rpx !important; /* 文字和图片之间的间距 */
}

/* 管理员模式下隐藏图片区域（原来在顶部的图片） */
.opt-grid.admin-mode .opt-card.admin-mode .opt-img {
  display: none !important;
}

/* 管理员模式下：文字区域在左边 */
.opt-grid.admin-mode .opt-card.admin-mode .opt-info {
  flex: 1 !important; /* 占据剩余空间 */
  padding: 0 !important; /* 移除内边距 */
  margin: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  align-items: flex-start !important; /* 左对齐 */
  text-align: left !important;
}

/* 管理员模式下：上传照片按钮在右边 */
.opt-grid.admin-mode .opt-card.admin-mode .admin-add-icon {
  position: static !important; /* 取消绝对定位 */
  width: 140rpx !important; /* 🔴 增大尺寸，更容易点击 */
  height: 140rpx !important;
  background: #F5F5F7 !important;
  border: 2rpx dashed #ddd !important;
  border-radius: 16rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 50rpx !important;
  flex-shrink: 0 !important; /* 不收缩 */
  margin: 0 !important;
  padding: 0 !important;
  /* 🔴 优化：如果有图片，显示图片预览 */
  overflow: hidden !important;
}

/* 🔴 优化：管理员模式下文字样式 */
.opt-grid.admin-mode .opt-card.admin-mode .opt-name {
  font-size: 36rpx !important; /* 字体更大 */
  font-weight: 700 !important;
  margin-bottom: 12rpx !important;
  color: #1c1c1e !important;
}
.opt-grid.admin-mode .opt-card.admin-mode .opt-sub {
  font-size: 28rpx !important; /* 字体更大 */
  color: #666 !important;
}

.opt-img { 
  width: 100%; 
  padding-bottom: 56.25%; /* 16:9 比例 */
  height: 0;
  background: #f0f0f0; 
  position: relative;
  overflow: hidden;
}
.opt-img image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.opt-info { 
  padding: 20rpx 10rpx; 
  width: 100%; 
  box-sizing: border-box; 
  position: relative;
  z-index: 1; /* 确保在图片下方 */
}
.opt-name { 
  font-size: 26rpx; 
  font-weight: 600; 
  display: block; 
  /* 🔴 优化：管理员模式下，文字可点击区域不阻挡其他操作 */
  pointer-events: auto;
  position: relative;
  z-index: 2;
}
.opt-sub { 
  font-size: 22rpx; 
  color: #666; 
  /* 🔴 优化：管理员模式下，文字可点击区域不阻挡其他操作 */
  pointer-events: auto;
  position: relative;
  z-index: 2;
}
.admin-add-icon { position: absolute; top: 10rpx; right: 10rpx; font-size: 20rpx; background: #eee; padding: 6rpx; border-radius: 6rpx; }
.admin-del-corner { 
  position: absolute !important; 
  top: 10rpx !important; 
  right: 10rpx !important; 
  background: rgba(255, 255, 255, 0.95) !important; 
  color: #FF3B30 !important; 
