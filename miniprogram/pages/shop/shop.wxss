}
.ms-num { width: 40rpx; text-align: center; font-size: 24rpx; font-weight: 600; }

/* 7. 底部单按钮 (立即支付) */
/* 🔴 结算弹窗内：收货信息 form 与下方免责协议尽量靠近 */
.checkout-body .form-group {
  margin-bottom: 12rpx;
}

/* 🔴 免责协议区域：紧跟收货信息 */
.disclaimer-section {
  margin-top: 4rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid #eee;
}

.disclaimer-checkbox {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.disclaimer-label {
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.disclaimer-checkbox .checkbox {
  margin-right: 12rpx;
  margin-top: 2rpx; /* 🔴 往上移一点 */
  transform: scale(0.9);
}

.disclaimer-text-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  line-height: 1.6;
}

.disclaimer-text {
  color: #666;
}

.disclaimer-link {
  color: #007AFF;
  text-decoration: underline;
}

.checkout-footer-single {
  position: absolute; bottom: 0; left: 0; width: 100%;
  /* 纯白实心背景，防止透视 */
  background: #FFFFFF;
  padding: 20rpx 30rpx calc(28rpx + env(safe-area-inset-bottom));  /* 底部减小：立即支付稍微往下 */
  border-top: 1rpx solid #eee; display: flex; justify-content: flex-start; box-sizing: border-box;
  z-index: 601;
  pointer-events: auto; /* 确保可以点击 */
}

.btn-black.full.disabled {
  background: #ccc !important;
  opacity: 0.6;
  pointer-events: none;
}

/* 🔴 确保按钮在禁用状态下不可点击 */
.btn-black.full.disabled:active {
  transform: none !important;
  opacity: 0.6 !important;
}

/* 未勾选免责时：灰色样式但可点击，点击后弹出「是否阅读免责协议」确认，确认即自动打钩 */
.btn-black.full.grayed {
  background: #ccc !important;
  opacity: 0.6;
  /* 不设 pointer-events: none，保持可点击 */
}

.btn-main { font-size: 30rpx; font-weight: 700; }
/* 去掉小字，如果 wxml 还有 btn-sub 也不显示 */
.btn-sub { display: none; }



/* ================= 自动消失提示样式（无按钮，3秒后自动消失，带收缩退出动画） ================= */
.auto-toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 99999999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none; /* 允许点击穿透 */
  animation: autoToastMaskFadeIn 0.25s ease-out forwards;
}
.auto-toast-mask.closing {
  animation: autoToastMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes autoToastMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.auto-toast-box {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 32rpx;
  padding: 48rpx 56rpx;
  max-width: 640rpx;
  min-width: 480rpx;
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.12),
    0 8rpx 24rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  animation: autoToastFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 移除自动退出，改为手动触发 */
  position: relative;
  overflow: hidden;
}
.auto-toast-mask.closing .auto-toast-box {
  animation: autoToastShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes autoToastShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx); /* 明显收缩并向上移动 */
    opacity: 0;
    filter: blur(12rpx); /* 更明显的模糊 */
  }
}

/* 添加微妙的边框 */
.auto-toast-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(0, 0, 0, 0.05));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

@keyframes autoToastFadeIn {
  from {
    opacity: 0;
    transform: translateY(-30rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* autoToastFadeOut 已移除，改用 autoToastShrinkOut（手动触发） */

