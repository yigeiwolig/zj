/* ================= 自定义操作菜单（替代 wx.showActionSheet） ================= */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10px);
  z-index: 99999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: dialogMaskFadeIn 0.25s ease-out forwards;
}
.action-sheet-mask.closing {
  animation: dialogMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.action-sheet-box {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.3s ease-out forwards;
}
.action-sheet-mask.closing .action-sheet-box {
  animation: slideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
@keyframes slideDown {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(100%);
    opacity: 0;
  }
}

.action-sheet-item {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  color: #000; /* 🔴 改为纯黑色 */
  border-bottom: 1rpx solid #E5E5EA;
  transition: background-color 0.2s;
}

.action-sheet-item:active {
  background-color: #F5F5F7;
}

.action-sheet-cancel {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  color: #000; /* 🔴 改为纯黑色 */
  margin-top: 16rpx;
  border-top: 16rpx solid #F5F5F7;
  transition: background-color 0.2s;
}

.action-sheet-cancel:active {
  background-color: #F5F5F7;
}
