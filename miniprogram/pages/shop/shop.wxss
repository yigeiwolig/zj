/* ================= 自定义弹窗 (替代 wx.showModal，带弹出+收缩退出动画) ================= */
.custom-dialog-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);
  z-index: 9999; display: flex; align-items: center; justify-content: center;
  animation: dialogMaskFadeIn 0.25s ease-out forwards;
}
.custom-dialog-mask.closing {
  animation: dialogMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes dialogMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.custom-dialog-box {
  width: 600rpx; background: #fff; border-radius: 40rpx; padding: 50rpx 40rpx;
  display: flex; flex-direction: column; align-items: center; text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
  animation: dialogBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 轻微回弹，灵动 */
}
.custom-dialog-mask.closing .custom-dialog-box {
  animation: dialogBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes dialogBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes dialogBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx); /* 明显收缩并向上移动 */
    opacity: 0;
    filter: blur(12rpx); /* 更明显的模糊 */
  }
}

