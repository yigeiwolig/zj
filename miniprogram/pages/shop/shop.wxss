/* --- 管理员编辑态样式优化 --- */

/* 基础可编辑类：保留大点击区域，但视觉隐形 */
.acc-detail-info .editable {
  position: relative;
  border-radius: 12rpx;
  /* 关键：负边距抵消 padding，保持视觉对齐的同时增加点击热区 */
  margin: -10rpx -20rpx; 
  padding: 10rpx 20rpx !important;
  cursor: pointer;
  transition: all 0.2s ease;
  border: 1px solid transparent; /* 预留边框位置防止抖动 */
}

/* 只有右侧一个小图标提示 */
.acc-detail-info .editable::after {
  content: '\270E'; /* ✎ 符号 */
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #0071e3;
  opacity: 0; /* 默认隐藏，看起来更干净 */
  transition: all 0.2s ease;
}

/* 管理员模式下，如果觉得完全隐藏太难找，可以给一个极淡的背景或虚线 */
/* 这里选择：默认干净，点击时反馈明显 */

/* 悬停或激活时显示编辑提示 */
.acc-detail-info .editable:active {
  background-color: rgba(0, 0, 0, 0.03); /* 极淡的灰底 */
}

.acc-detail-info .editable:active::after {
  opacity: 1;
  transform: translateY(-50%) scale(1.1);
}

/* 如果是管理员，给一个初始的弱提示 (可选) */
/* 为了不low，我们只用虚线底边框提示，或者干脆只靠位置感 */
.acc-detail-info .editable {
   /* 方案：右侧始终有一个非常淡的图标，不抢眼 */
}
.acc-detail-info .editable::after {
  opacity: 0.3; /* 常态下淡淡的 */
}

/* ============================================================== */
/* 1. 新增：自定义顶部错误提示 (替代 ugly toast) */
/* ============================================================== */
.top-error-toast {
  position: fixed; top: -100rpx; left: 0; width: 100%;
  height: 80rpx; line-height: 80rpx;
  background: #FF3B30; color: #fff;
  text-align: center; font-size: 28rpx; font-weight: 600;
  z-index: 9999;
  transition: top 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  box-shadow: 0 4rpx 10rpx rgba(255, 59, 48, 0.3);
}
.top-error-toast.show { top: 0; }

/* ============================================================== */
/* 2. 加入成功弹窗 (Success Modal) - 弹出 + 收缩退出动画 */
/* ============================================================== */
.success-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(5px);
  z-index: 900; display: flex; align-items: center; justify-content: center;
  animation: cartMaskFadeIn 0.25s ease-out forwards;
}
.success-mask.closing {
  animation: cartMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes cartMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
@keyframes cartMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.success-box {
  background: #fff; width: 600rpx; border-radius: 50rpx; padding: 70rpx 50rpx;
  display: flex; flex-direction: column; align-items: center; text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  animation: cartBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 轻微回弹，灵动 */
}
.success-mask.closing .success-box {
  animation: cartBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes cartBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx); /* 明显收缩并向上移动 */
    opacity: 0;
    filter: blur(12rpx); /* 更明显的模糊 */
  }
}
@keyframes cartBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
.s-icon {
  width: 120rpx; height: 120rpx; background: #E1F8E8; color: #00C853;
  border-radius: 50%; font-size: 60rpx; line-height: 120rpx; font-weight: bold;
  margin-bottom: 40rpx;
}
.s-title { font-size: 36rpx; font-weight: 800; color: #1D1D1F; margin-bottom: 16rpx; }
.s-desc { font-size: 26rpx; color: #86868b; margin-bottom: 50rpx; }

.s-btn-row { width: 100%; display: flex; gap: 20rpx; }
.s-btn {
