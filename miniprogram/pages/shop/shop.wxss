/* ================================================= */
/* 极简无底播放/暂停图标 (仿抖音风格) */
/* ================================================= */

/* 公共容器样式 - 去掉所有背景，只保留占位 */
.play-icon, 
.pause-icon {
  width: 140rpx;
  height: 140rpx;
  
  /* 🔴 核心修改：去掉背景、模糊、边框、阴影 */
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border: none;
  box-shadow: none;
  border-radius: 0;
  
  display: flex;
  align-items: center;
  justify-content: center;
  
  position: relative;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  cursor: pointer;
  
  /* 🔴 禁用点击高亮（解决蓝色底问题） */
  -webkit-tap-highlight-color: transparent;
  tap-highlight-color: transparent;
  user-select: none;
  -webkit-user-select: none;
}

/* 点击时的缩放反馈 */
.play-icon:active,
.pause-icon:active {
  transform: scale(0.9);
  background: transparent !important; /* 保持透明，强制覆盖 */
  -webkit-tap-highlight-color: transparent !important;
  tap-highlight-color: transparent !important;
}

/* 播放三角形 */
.play-triangle {
  width: 0;
  height: 0;
  
  /* 🔴 核心修改：灰色半透明，无底 */
  border-left: 50rpx solid rgba(255, 255, 255, 0.6); /* 浅灰色/半透明白 */
  border-top: 32rpx solid transparent;
  border-bottom: 32rpx solid transparent;
  
  /* 视觉居中修正 */
  margin-left: 14rpx; 
  
  /* 简单的阴影增加可见度 */
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.2));
  transition: all 0.2s ease;
}

/* 点击时图标变暗一点 */
.play-icon:active .play-triangle {
  border-left-color: rgba(255, 255, 255, 0.4);
}

/* 暂停图标布局 */
.pause-icon {
  gap: 18rpx;
}

/* 暂停竖条 */
.pause-bar {
  width: 14rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.6); /* 浅灰色/半透明白 */
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
  transition: all 0.2s ease;
}

/* 点击时竖条变暗 */
.pause-icon:active .pause-bar {
  background: rgba(255, 255, 255, 0.4);
}

/* 移除之前的伪元素和多余动画 */
.play-icon::before,
.pause-icon::before {
  display: none;
}
.pause-bar-left, .pause-bar-right {
  margin: 0; 
}

/* 视频容器 - 16:9比例 */
.hero-video-wrapper,
.detail-video-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.hero-video-wrapper video,
.detail-video-wrapper video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 全屏播放器的暂停覆盖层 */
.video-pause-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  z-index: 100001;
  pointer-events: auto;
  
  /* 🔴 禁用点击高亮（解决蓝色底问题） */
  -webkit-tap-highlight-color: transparent;
  tap-highlight-color: transparent;
  user-select: none;
  -webkit-user-select: none;
  
  /* 🔴 核心动画：默认隐藏 */
  opacity: 0;
  transform: scale(1.2);
  transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  visibility: hidden;
}

/* 暂停时显示 */
.video-pause-overlay.show {
  opacity: 1;
  transform: scale(1);
  visibility: visible;
}


