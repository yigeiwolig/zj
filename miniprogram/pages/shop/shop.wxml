<!-- pages/shop/shop.wxml -->
<wxs module="utils" src="./shop.wxs"></wxs>
<view class="container">

<!-- ================= 1. 顶部导航 ================= -->
<!-- 顶部返回，只在主列表显示，深色背景用白色箭头 -->
<view class="header" wx:if="{{!showOrderModal && !showDetail}}" style="padding-top: {{statusBarHeight}}px;">
  <view class="back-icon" catchtap="goBack" style="top: {{statusBarHeight + 10}}px;">
    <text class="back-arrow">‹</text>
  </view>
</view>
<view class="nav-header" style="padding-top: {{statusBarHeight}}px; height: {{statusBarHeight + navBarHeight + 20}}px;">
  <!-- 左侧：返回按钮 -->
  <view class="nav-left">
  </view>
  
  <!-- 中间区域：标题和管理员切换按钮 -->
  <view class="brand-title" bindtap="handleTitleClick" style="top: {{statusBarHeight + navBarHeight / 2}}px;">
    <text>{{shopTitle || 'MT 配件中心'}}</text>
    <!-- 只有白名单用户能看到的切换开关 -->
    <view 
      wx:if="{{isAuthorized}}" 
      class="admin-toggle-btn {{isAdmin ? 'on' : ''}}" 
      catchtap="toggleAdminMode">
      {{isAdmin ? 'EXIT' : 'EDIT'}}
    </view>
  </view>
  
  <view class="nav-right"></view>
</view>

<!-- ================= 2. 主页面 ================= -->
<scroll-view scroll-y class="main-scroll">
  
  <!-- 顶部轮播 (Hero) -->
  <view class="hero-swiper-box">
    <swiper class="hero-swiper" indicator-dots="{{true}}" circular="{{true}}" autoplay="{{!isAdmin}}" bindchange="onSwiperChange">
      <block wx:for="{{topMediaList}}" wx:key="url">
        <swiper-item>
          <view wx:if="{{item.type === 'video'}}" class="hero-video-wrapper">
            <video 
              src="{{item.url}}" 
              class="hero-media" 
              id="hero-video-{{index}}"
              autoplay="{{item.autoplay || (!isAdmin && index === 0 && item.type === 'video')}}"
              preload="metadata"
              muted 
              loop 
              show-play-btn="{{false}}" 
              show-center-play-btn="{{false}}"
              controls="{{false}}"
              bindplay="onVideoPlay"
              bindpause="onVideoPause"
              binderror="onVideoError"
              data-index="{{index}}"
              data-location="hero"
            ></video>
            <view class="video-play-overlay" bindtap="playVideo" data-index="{{index}}" data-url="{{item.url}}" data-location="hero">
              <view class="play-icon" wx:if="{{!heroVideoPlaying[index]}}">
                <view class="play-triangle"></view>
              </view>
            </view>
          </view>
          <image wx:else src="{{item.url}}" class="hero-media" mode="aspectFill" />
          
          <view wx:if="{{isAdmin}}" class="admin-del-media" catchtap="adminDelTopMedia" data-index="{{index}}">✕</view>
        </swiper-item>
      </block>
    </swiper>
    
    <!-- Admin: 拖拽排序模式 -->
    <view class="media-drag-list" wx:if="{{isAdmin && isEditingMedia}}">
      <view class="drag-tip">长按拖动调整顺序，置顶项会显示在最前</view>
      <block wx:for="{{sortedTopMediaList}}" wx:key="url" wx:for-index="dragIndex">
        <view class="drag-item" 
              data-index="{{item.originalIndex}}"
              bindtouchstart="onDragStart"
              bindtouchmove="onDragMove"
              bindtouchend="onDragEnd">
          <view class="drag-item-preview">
            <image wx:if="{{item.type === 'image'}}" src="{{item.url}}" mode="aspectFill" class="drag-preview-img"></image>
            <view wx:else class="drag-preview-video">
              <text>🎥 视频</text>
            </view>
          </view>
          <view class="drag-item-info">
            <text class="drag-item-type">{{item.type === 'image' ? '图片' : '视频'}}</text>
            <view class="drag-item-badges">
              <text wx:if="{{item.isPinned}}" class="badge pin-badge">置顶</text>
              <text wx:if="{{item.autoplay && item.type === 'video'}}" class="badge autoplay-badge">自动播放</text>
            </view>
          </view>
          <view class="drag-handle">☰</view>
        </view>
      </block>
      <view class="drag-actions">
        <view class="drag-btn cancel" bindtap="adminCancelDrag">取消</view>
        <view class="drag-btn confirm" bindtap="adminConfirmDrag">完成</view>
      </view>
    </view>
    
    <!-- Admin: 左右分开的上传按钮 -->
    <view class="admin-upload-row" wx:if="{{isAdmin && !isEditingMedia}}">
       <view class="up-btn" bindtap="adminAddImage">📷 上传图片</view>
       <view class="up-btn" bindtap="adminAddVideo">🎥 上传视频</view>
    </view>
  </view>

  <!-- 产品列表 (单列大卡片) -->
  <view class="product-list">
    <block wx:for="{{seriesList}}" wx:key="id">
      <view class="prod-card" bindtap="handleProductClick" data-index="{{index}}">
        <view class="product-cover-wrapper">
          <image class="p-img" src="{{item.cover}}" mode="aspectFill" />
          <!-- 跳转号码标识（管理员模式下可编辑） -->
          <view wx:if="{{isAdmin}}" class="jump-number-badge" catchtap="adminEditJumpNumber" data-index="{{index}}">
            <text wx:if="{{item.jumpNumber}}">#{{item.jumpNumber}}</text>
            <text wx:else>#</text>
          </view>
        </view>
        <view class="admin-float" wx:if="{{isAdmin}}" catchtap="adminUploadCover" data-index="{{index}}">📷</view>
        
        <!-- 红色删除按钮 -->
        <view class="admin-del-card-btn" wx:if="{{isAdmin}}" catchtap="adminDeleteSeries" data-index="{{index}}">✕</view>
        
        <view class="p-info">
           <view class="p-row">
             <text class="p-title {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditSeriesName':''}}" data-index="{{index}}">{{item.name}}</text>
             <view class="p-price-wrapper {{isAdmin ? 'editable' : ''}}" catchtap="{{isAdmin ? 'adminEditSeriesPrice' : ''}}" data-index="{{index}}">
               <text class="p-price">{{item.priceDisplay || '¥' + item.models[0].price + ' 起'}}</text>
             </view>
           </view>
        </view>
      </view>
    </block>
    <!-- Admin 添加产品 -->
    <view class="add-series-btn" wx:if="{{isAdmin}}" bindtap="adminAddSeries">+ 添加新产品系列</view>
  </view>

  <view style="height: 100rpx;"></view>
</scroll-view>

<!-- ================= 3. 产品详情弹窗 (Detail) ================= -->
<view class="full-modal {{showDetail ? 'active' : ''}}">
  <!-- 弹窗头 -->
  <view class="modal-nav">
    <view class="nav-close" catchtap="closeDetail">✕</view>
    <!-- 管理员模式下：标题可点击编辑 -->
    <view 
      class="modal-title {{isAdmin ? 'editable' : ''}}" 
      catchtap="{{isAdmin ? 'adminEditSeriesNameInDetail' : ''}}">
      {{currentSeries.name}}
    </view>
    <view style="width:60rpx"></view>
  </view>

  <!-- 弹窗内容区 -->
  <scroll-view scroll-y class="modal-scroll" bindscroll="onDetailScroll">
    <view class="scroll-inner">
      
      <!-- (A) 详情长图/视频 -->
      <view class="detail-images">
         <block wx:for="{{currentSeries.detailImages}}" wx:key="url">
           <view class="dimg-box {{isAdmin && isDetailDragging && detailDragIndex === index ? 'dragging' : ''}}"
                 style="{{isAdmin && isDetailDragging && detailDragIndex === index ? 'transform: translateY(' + detailDragOffsetY + 'px) scale(1.02);' : ''}}"
                 bindtouchstart="{{isAdmin ? 'onDetailDragStart' : ''}}"
                 catchtouchmove="{{isAdmin ? 'onDetailDragMove' : ''}}"
                 bindtouchend="{{isAdmin ? 'onDetailDragEnd' : ''}}"
                 data-index="{{index}}">
              <view wx:if="{{item.type === 'video'}}" class="detail-video-wrapper">
                <video 
                  src="{{item.url}}" 
                  class="dimg" 
                  id="detail-video-{{index}}"
                  autoplay="{{item.autoplay || false}}"
                  preload="metadata"
                  muted 
                  loop 
                  show-play-btn="{{false}}" 
                  show-center-play-btn="{{false}}"
                  controls="{{false}}"
                  bindplay="onVideoPlay"
                  bindpause="onVideoPause"
                  binderror="onVideoError"
                  data-index="{{index}}"
                  data-location="detail"
                ></video>
                <view class="video-play-overlay" bindtap="playVideo" data-index="{{index}}" data-url="{{item.url}}" data-location="detail" wx:if="{{!isDetailDragging}}">
                  <view class="play-icon" wx:if="{{!detailVideoPlaying[index]}}">
                    <view class="play-triangle"></view>
                  </view>
                </view>
                <!-- 🔴 详情页视频的管理员控制开关 -->
                <view wx:if="{{isAdmin && !isDetailDragging}}" class="admin-detail-video-controls">
                  <view class="video-control-item">
                    <text class="control-label">置顶</text>
                    <view class="switch-toggle {{item.isPinned ? 'on' : ''}}" catchtap="adminToggleDetailVideoPin" data-index="{{index}}">
                      <view class="switch-thumb"></view>
                    </view>
                  </view>
                  <view class="video-control-item">
                    <text class="control-label">自动播放</text>
                    <view class="switch-toggle {{item.autoplay ? 'on' : ''}}" catchtap="adminToggleDetailVideoAutoplay" data-index="{{index}}">
                      <view class="switch-thumb"></view>
                    </view>
                  </view>
                </view>
              </view>
              <image wx:else src="{{item.url}}" mode="aspectFill" class="dimg" />
              
              <view wx:if="{{isAdmin && !isDetailDragging}}" class="admin-del-abs" catchtap="adminDelDetailImg" data-index="{{index}}">✕</view>
           </view>
         </block>
         <view class="add-txt-btn" wx:if="{{isAdmin}}" bindtap="adminAddDetailMedia">+ 添加详情图片/视频</view>
      </view>

      <!-- 2. 选购配置区 -->
      <view class="config-sec">
        
        <!-- 标题行 -->
        <view class="sec-header-row">
            <view class="sec-title {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditLabel':''}}" data-key="configTitle">
              {{currentSeries.labels.configTitle || '选购配置'}}
            </view>
            <!-- 对比按钮 -->
            <view class="btn-compare" 
                  wx:if="{{currentSeries.models.length > 1}}" 
                  bindtap="toggleModelCompareMode">
              {{isModelCompareMode ? '取消选择' : '参数对比'}}
            </view>
        </view>

        <!-- 对比确认条 -->
        <view wx:if="{{isModelCompareMode}}" style="text-align:center; margin-bottom:20rpx;">
          <view class="btn-black" style="display:inline-block; font-size:24rpx; padding:10rpx 40rpx;" bindtap="startCompare">
            开始对比 (已选{{compareSelectedModels.length}})
          </view>
        </view>

        <!-- A. 选择型号 -->
        <view class="cfg-group">
          <view class="cfg-label {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditLabel':''}}" data-key="modelTitle">
            {{currentSeries.labels.modelTitle || '选择型号'}}
          </view>
          
          <block wx:for="{{currentSeries.models}}" wx:key="name">
            <view 
              class="model-card-normal {{ (!isModelCompareMode && selectedModelIdx === index) || (isModelCompareMode && item.isCompareChecked) ? 'selected' : ''}}" 
              bindtap="selectModel" 
              data-index="{{index}}">
              
              <view wx:if="{{isModelCompareMode}}" class="circle {{item.isCompareChecked ? 'checked' : ''}}" style="margin-right:20rpx;"></view>

              <view style="flex:1">
                  <text class="m-name {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditModelName':''}}" data-midx="{{index}}">{{item.name}}</text>
                  <text class="m-desc {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditModelDesc':''}}" data-midx="{{index}}">{{item.desc || (isAdmin ? '点击添加描述' : '')}}</text>
              </view>
              
              <!-- 🔴 优化：把价格包装在 view 中，根据管理员模式设置不同的 class -->
              <!-- 🔴 修复：非管理员模式下使用 bindtap 或不绑定，避免阻止事件冒泡 -->
              <view class="m-price-wrapper {{isAdmin ? 'm-price-wrapper-admin' : 'm-price-wrapper-normal'}}" catchtap="{{isAdmin ? 'adminEditModelPrice' : ''}}" data-midx="{{index}}">
                <text class="m-price {{isAdmin?'editable':''}}">¥{{item.price}}</text>
              </view>
              
              <view wx:if="{{isAdmin}}" class="admin-del-mini" catchtap="adminDelModel" data-midx="{{index}}">✕</view>
            </view>
          </block>
          <view wx:if="{{isAdmin}}" class="add-txt-btn" bindtap="adminAddModel">+ 添加型号</view>
        </view>

        <!-- B. 配置方案 -->
        <view class="cfg-group">
          <view class="cfg-label {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditLabel':''}}" data-key="optionTitle">
            {{currentSeries.labels.optionTitle || '配置方案'}}
          </view>
          <view class="opt-grid {{isAdmin ? 'admin-mode' : ''}}">
             <block wx:for="{{currentSeries.options}}" wx:key="name">
                <view class="opt-card {{selectedOptionIdx === index ? 'selected' : ''}} {{isAdmin ? 'admin-mode' : ''}}" bindtap="selectOption" data-index="{{index}}">
                   <!-- 普通模式：显示图片 -->
                   <image wx:if="{{item.img && !isAdmin}}" src="{{item.img}}" class="opt-img" mode="aspectFill" />
                   
                   <!-- 管理员模式：左边文字区域 -->
                   <view class="opt-info">
                      <text class="opt-name {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditOptName':''}}" data-oidx="{{index}}">{{item.name}}</text>
                      <text class="opt-sub {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditOptPrice':''}}" data-oidx="{{index}}">{{item.price > 0 ? '+¥'+item.price : '标配'}}</text>
                   </view>
                   
                   <!-- 管理员模式：右边上传照片按钮 -->
                   <view wx:if="{{isAdmin}}" class="admin-add-icon" catchtap="adminUploadOptionImg" data-oidx="{{index}}">
                     <image wx:if="{{item.img}}" src="{{item.img}}" style="width: 100%; height: 100%; border-radius: 14rpx; object-fit: cover;" mode="aspectFill" />
                     <text wx:else style="font-size: 50rpx;">📷</text>
                   </view>
                   
                   <!-- 删除按钮 -->
                   <view wx:if="{{isAdmin}}" class="admin-del-corner" catchtap="adminDelOption" data-oidx="{{index}}">✕</view>
                </view>
             </block>
             <view class="opt-card add-btn {{isAdmin ? 'admin-mode' : ''}}" wx:if="{{isAdmin}}" bindtap="adminAddOption">+</view>
          </view>
        </view>

        <!-- C. 配件加购 -->
        <view class="cfg-group" wx:if="{{accessoryList.length > 0 || isAdmin}}">
          <view class="cfg-label {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditLabel':''}}" data-key="accTitle">
            {{currentSeries.labels.accTitle || '配件加购'}}
          </view>
          <view class="acc-list-v">
            <block wx:for="{{accessoryList}}" wx:key="id">
               <view class="acc-row-card {{item.selected ? 'selected' : ''}} {{item.isRequired ? 'required-highlight' : ''}} {{item.isRequired && item.selected ? 'required-selected' : ''}}" 
                     bindtap="openAccessoryDetail" data-index="{{index}}">
            
            <image class="acc-thumb" src="{{item.img}}" mode="aspectFill" />
            <view wx:if="{{isAdmin}}" class="admin-float-thumb" catchtap="adminUploadAccThumb" data-index="{{index}}">📷</view>

            <view class="acc-info">
                <text class="acc-n">{{item.name}}</text>
                <text class="acc-p">¥{{item.price}}</text>
                <!-- 🔴 新增：需要购买的标识 -->
                <text class="acc-required-tag" wx:if="{{item.isRequired && !item.selected}}">需要购买</text>
            </view>

            <view class="acc-add-btn {{item.selected ? 'checked' : ''}} {{item.isRequired ? 'required-btn' : ''}}" 
                  catchtap="toggleAccessorySelection" 
                  data-index="{{index}}">
               {{item.selected ? '已选' : '添加'}}
            </view>
            
            <view wx:if="{{isAdmin}}" class="admin-del-corner-top" catchtap="adminDelAcc" data-index="{{index}}">✕</view>
          </view>
            </block>
      <view wx:if="{{isAdmin}}" class="add-txt-btn" bindtap="adminAddAcc">+ 添加配件</view>
    </view>
  </view>

      </view>
      <view style="height:200rpx;"></view> 
    </view>
  </scroll-view>

  <!-- 2. 底部结算栏 -->
  <view class="modal-footer {{showFooterBar ? 'visible' : ''}}">
    <view class="footer-btn-group">
      <view class="btn-cart" id="cart-target" bindtap="addToCart">加入购物车</view>
      <view class="btn-buy" bindtap="openCartOrder">立即购买</view>
    </view>
  </view>
</view>

<!-- ================= 4. 对比表格弹窗 (最终修正版) ================= -->
<!-- 遮罩层 -->
<view class="dark-mask" wx:if="{{showSpecsModal}}" bindtap="closeSpecsModal" catchtouchmove="noop" style="z-index: 998;"></view>

<!-- 弹窗主体 -->
<view class="overlay {{showSpecsModal ? 'active' : ''}}" catchtap="stopPropagation" catchtouchmove="noop">
  
  <!-- 1. 标题栏 (白色背景) -->
  <view class="overlay-head">
    <text>对比详情</text>
    <view catchtap="closeSpecsModal" class="close">✕</view>
  </view>
  
  <!-- 2. 灰色胶囊表头 (固定不动，位于标题栏下方) -->
  <view class="specs-header-container">
    <view class="capsule-header">
      <view class="sp-cell label">参数项</view>
      <block wx:for="{{compareData.headers}}" wx:key="*this">
        <view class="sp-cell">{{item}}</view>
      </block>
      <view wx:if="{{isAdmin}}" class="sp-cell admin-w"></view>
    </view>
  </view>
  
  <!-- 3. 滚动内容区 -->
  <scroll-view scroll-y class="specs-scroll-body" enable-back-to-top="{{true}}">
    <view class="specs-table-content">
       
       <block wx:for="{{compareData.rows}}" wx:key="label" wx:for-index="rowIdx">
         <view class="sp-row">
            <view class="sp-cell label {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditSpecCell':''}}" data-row="{{rowIdx}}" data-key="label">{{item.label}}</view>
            <block wx:for="{{item.vals}}" wx:for-item="val" wx:key="*this" wx:for-index="valIdx">
               <view class="sp-cell {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditSpecCell':''}}" data-row="{{rowIdx}}" data-key="v{{valIdx+1}}">{{val}}</view>
            </block>
            <view wx:if="{{isAdmin}}" class="sp-cell admin-w" catchtap="adminDelSpecRow" data-index="{{rowIdx}}">✕</view>
         </view>
       </block>
       
       <view wx:if="{{isAdmin}}" class="add-txt-btn" bindtap="adminAddSpecRow">+ 添加参数行</view>
       
       <!-- 底部视频按钮 -->
       <view class="compare-btn-area" 
             wx:if="{{isAdmin || (currentSeries.compareVideo && currentSeries.showCompareVideo)}}">
         <view class="btn-watch-compare" bindtap="watchCompareVideo">
           <text class="icon-play" style="margin-right: 10rpx;">▶</text> 查看对比演示视频
         </view>

         <view class="admin-video-controls" wx:if="{{isAdmin}}">
           <view class="admin-v-btn upload" bindtap="adminUploadCompareVideo">
             {{currentSeries.compareVideo ? '更换视频' : '上传视频'}}
           </view>
           <view class="admin-v-btn toggle {{currentSeries.showCompareVideo ? 'on' : 'off'}}" 
                 bindtap="adminToggleVideoVis">
             {{currentSeries.showCompareVideo ? '显示中' : '已隐藏'}}
           </view>
         </view>

       </view>

    </view>
  </scroll-view>
</view>

<!-- ================= 5. 配件详情弹窗 ================= -->
<view class="full-modal {{showAccDetail ? 'active' : ''}}" style="z-index: 300;">
  <view class="modal-nav">
     <view class="nav-close" bindtap="closeAccessoryDetail">✕</view>
     <view class="modal-title">配件详情</view>
     <view style="width:60rpx"></view>
  </view>
  <scroll-view scroll-y class="modal-scroll">
     <view class="acc-detail-hero">
        <image wx:if="{{accessoryList[currentAccIdx].detailImages.length>0}}" 
               src="{{accessoryList[currentAccIdx].detailImages[0]}}" mode="aspectFill" class="dimg"/>
        <view wx:else class="acc-hero-placeholder">
          <view class="acc-hero-placeholder-icon">📷</view>
          <text class="acc-hero-placeholder-text">暂无图片</text>
        </view>
        
        <view wx:if="{{isAdmin}}" class="acc-hero-upload-btn" bindtap="adminAddAccDetailImg">
          <text class="acc-hero-upload-icon">📷</text>
          <text class="acc-hero-upload-text">添加图片</text>
        </view>
     </view>
     
     <view class="acc-detail-info">
        <!-- 名称 -->
        <view class="acc-d-row">
          <text class="acc-d-label">配件名称</text>
          <view class="acc-d-name {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditAccName':''}}">{{accessoryList[currentAccIdx] ? accessoryList[currentAccIdx].name : ''}}</view>
        </view>
        
        <!-- 价格 -->
        <view class="acc-d-row">
          <text class="acc-d-label">价格</text>
          <view class="acc-d-price {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditAccPrice':''}}">¥{{accessoryList[currentAccIdx] ? utils.formatPrice(accessoryList[currentAccIdx].price) : '0'}}</view>
        </view>

        <!-- 描述 -->
        <view class="acc-d-row">
          <text class="acc-d-label">详细描述</text>
          <view class="acc-d-desc {{isAdmin?'editable':''}}" catchtap="{{isAdmin?'adminEditAccDesc':''}}">{{accessoryList[currentAccIdx] ? (accessoryList[currentAccIdx].desc || '暂无描述') : ''}}</view>
        </view>
     </view>
  </scroll-view>
  
  <view class="modal-footer">
     <view></view>
     <view class="btn-black full" bindtap="addAccToCartFromDetail">加入购物袋</view>
  </view>
</view>

<!-- ================= 6. 加入购物车成功弹窗（弹出+收缩退出动画） ================= -->
<view class="success-mask {{cartSuccessClosing ? 'closing' : ''}}" wx:if="{{showCartSuccess}}" catchtouchmove="noop" catchtap="noop">
  <view class="success-box" catchtouchmove="noop" catchtap="noop">
    <view class="s-icon">✔</view>
    <view class="s-title">已加入购物车</view>
    <view class="s-desc">商品已保存，您可以继续选购或去结算</view>
    
    <view class="s-btn-row">
      <view class="s-btn outline" bindtap="onContinueShopping">继续选购</view>
      <view class="s-btn fill" bindtap="onGoToCheckout">立即结算</view>
    </view>
  </view>
</view>

<!-- ================= 7. 订单确认/结算弹窗 ================= -->
<view class="dark-mask" wx:if="{{showOrderModal}}" bindtap="closeOrderModal"></view>

<view class="overlay full-screen-overlay {{showOrderModal ? 'active' : ''}}" style="z-index: 600;">
  <!-- 顶部 -->
  <view class="checkout-header">
    <view class="nav-close" bindtap="closeOrderModal">✕</view>
    <view class="co-title">确认订单</view>
    <view style="width:40rpx"></view>
  </view>

  <scroll-view scroll-y class="checkout-scroll">
    <view class="checkout-body">
      
      <!-- 商品清单 -->
      <view class="group-card">
        <view class="cart-header-row">
          <view class="cart-title">商品清单</view>
          <view class="clear-btn-stylish" bindtap="clearCart">
            <text>🗑 清空</text>
          </view>
        </view>

        <block wx:for="{{cart}}" wx:key="id">
          <view class="cart-row">
            <view class="cr-info">
              <view class="cr-name">{{item.name}}</view>
              <view class="cr-spec">{{item.spec}}</view>
            </view>
            
            <view class="cr-action">
              <view class="cr-price">¥{{item.total}}</view>
              <view class="mini-stepper">
                <view class="ms-btn" catchtap="handleCartQty" data-index="{{index}}" data-type="minus">-</view>
                <view class="ms-num">{{item.quantity}}</view>
                <view class="ms-btn" catchtap="handleCartQty" data-index="{{index}}" data-type="plus">+</view>
              </view>
            </view>
          </view>
        </block>
        
        <view wx:if="{{cart.length === 0}}" class="empty-cart">购物车暂无商品</view>
        
      </view>

      <!-- 配送方式 -->
      <view class="group-header-row">
        <view class="group-title-text">配送方式</view>
      </view>
      <view class="shipping-box">
        <view class="ship-item {{shippingMethod=='zto'?'active':''}}" bindtap="changeShipping" data-method="zto">
          <view class="ship-name">中通快递</view>
          <view class="ship-price">包邮</view>
        </view>
        <!-- 顺丰选项 -->
        <view class="ship-item {{shippingMethod=='sf'?'active':''}}" bindtap="changeShipping" data-method="sf">
          <view class="ship-name">顺丰速运</view>
          <view class="ship-price">
             <!-- 如果没填地址或解析不到省份，显示待计算；否则显示金额 -->
             {{!detailAddress || shippingFee == 0 ? '待计算' : '¥'+shippingFee}}
             <text style="font-size:20rpx; color:#999; display:block;">(省内13/省外22)</text>
          </view>
        </view>
      </view>

      <!-- 总价显示区 -->
      <view class="final-total-row">
        <text class="ft-label">共 {{cart.length}} 件，总计</text>
        <text class="ft-price">¥{{isAdmin ? 0.01 : finalTotalPrice}}</text>
      </view>

      <!-- 收货信息 -->
      <view class="group-header-row">
        <view class="group-title-text">收货信息</view>
        <view class="paste-btn-header" bindtap="openSmartPasteModal">智能粘贴</view>
      </view>

      <view class="group-card form-group">

        <!-- 姓名 -->
        <view class="form-item">
          <view class="form-label">收货人</view>
          <input class="form-input" placeholder="请填写姓名" placeholder-class="ph-style" bindinput="onInput" data-key="name" value="{{orderInfo.name}}"/>
        </view>

        <!-- 手机号 -->
        <view class="form-item">
          <view class="form-label">手机号</view>
          <input class="form-input" type="number" maxlength="11" placeholder="请填写11位手机号" placeholder-class="ph-style" bindinput="onInput" data-key="phone" value="{{orderInfo.phone}}"/>
        </view>

        <!-- 🔴 新增：省市区选择（复制自 shouhou 页面） -->
        <view class="form-item">
          <view class="form-label">省市区</view>
          <view class="address-picker-row">
            <picker mode="selector" range="{{provinceList}}" range-key="name" value="{{provinceIndex}}" bindchange="onProvinceChange" class="address-picker-btn">
              <view class="address-picker-btn-inner {{!selectedProvince ? 'placeholder' : ''}}">
                <text class="address-picker-text">{{selectedProvince || '请选择省份'}}</text>
              </view>
            </picker>
            <picker mode="selector" range="{{cityList}}" range-key="name" value="{{cityIndex}}" bindchange="onCityChange" class="address-picker-btn" disabled="{{!selectedProvince}}">
              <view class="address-picker-btn-inner {{!selectedCity ? 'placeholder' : ''}} {{!selectedProvince ? 'disabled' : ''}}">
                <text class="address-picker-text">{{selectedCity || '请选择城市'}}</text>
              </view>
            </picker>
            <picker mode="selector" range="{{districtList}}" range-key="name" value="{{districtIndex}}" bindchange="onDistrictChange" class="address-picker-btn" disabled="{{!selectedCity}}">
              <view class="address-picker-btn-inner {{!selectedDistrict ? 'placeholder' : ''}} {{!selectedCity ? 'disabled' : ''}}">
                <text class="address-picker-text">{{selectedDistrict || '请选择区县'}}</text>
              </view>
            </picker>
          </view>
        </view>

        <!-- [修改] 详细地址 -->
        <view class="form-item">
          <view class="form-label">详细地址</view>
          <input class="form-input" placeholder="如：某某街道101号" placeholder-class="ph-style" bindinput="onInput" data-key="detailAddress" value="{{detailAddress}}"/>
        </view>

      </view>

      <!-- 免责协议（保持在最下面，位置稍微高一点） -->
      <view class="disclaimer-section">
        <view class="disclaimer-checkbox">
          <checkbox-group bindchange="onDisclaimerChange">
            <label class="disclaimer-label">
              <checkbox value="agree" checked="{{agreedToDisclaimer}}"/>
              <view class="disclaimer-text-wrapper">
                <text class="disclaimer-text">我已阅读并同意</text>
                <text class="disclaimer-link" catchtap="showDisclaimerModal">《免责协议》</text>
              </view>
            </label>
          </checkbox-group>
        </view>
      </view>

    </view>
  </scroll-view>

  <!-- 底部单按钮 (立即支付) -->
  <view class="checkout-footer-single">
    <view class="btn-black full {{!agreedToDisclaimer ? 'grayed' : ''}}" catchtap="submitOrder" data-agreed="{{agreedToDisclaimer}}">
      <text class="btn-main">立即支付 ¥{{(isAdmin || isAuthorized) ? 0.01 : finalTotalPrice}}</text>
    </view>
  </view>
</view>

<!-- ================= 8. 自定义编辑弹窗 ================= -->
<view class="custom-modal-mask {{customModalClosing ? 'closing' : ''}}" wx:if="{{showCustomEditModal}}" catchtouchmove="noop" catchtap="noop">
  <view class="custom-modal-box" catchtouchmove="noop" catchtap="noop">
    <view class="custom-modal-title">{{customEditTitle}}</view>
    <input class="custom-modal-input" value="{{customEditVal}}" bindinput="onCustomEditInput" focus="{{showCustomEditModal}}" cursor-spacing="100"/>
    <view class="custom-modal-btn-row">
      <view class="custom-btn c-btn-cancel" bindtap="closeCustomEditModal">取消</view>
      <view class="custom-btn c-btn-confirm" bindtap="confirmCustomEdit">确定</view>
    </view>
  </view>
</view>

<!-- ================= 自定义弹窗（替换 wx.showModal，带收缩退出动画） ================= -->
<view class="custom-dialog-mask {{dialogClosing ? 'closing' : ''}}" wx:if="{{dialog.show}}" catchtouchmove="noop" catchtap="noop">
  <view class="custom-dialog-box" catchtouchmove="noop" catchtap="noop">
    <view class="cd-title">{{dialog.title}}</view>
    <rich-text class="cd-content" nodes="{{dialog.content}}"></rich-text>
    <view class="cd-btn-row">
      <view class="cd-btn cancel" wx:if="{{dialog.showCancel}}" bindtap="closeCustomDialog">{{dialog.cancelText}}</view>
      <view class="cd-btn confirm" bindtap="onDialogConfirm">{{dialog.confirmText}}</view>
    </view>
  </view>
</view>

<!-- ================= 自动消失提示（无按钮，2秒后自动消失，带收缩退出动画） ================= -->
<view class="auto-toast-mask {{autoToastClosing ? 'closing' : ''}}" wx:if="{{autoToast.show}}" catchtouchmove="noop" catchtap="noop">
  <view class="auto-toast-box" catchtouchmove="noop" catchtap="noop">
    <view class="at-title">{{autoToast.title}}</view>
    <view class="at-content">{{autoToast.content}}</view>
  </view>
</view>

<!-- ================= 9. 屏幕中间提示气泡 ================= -->
<view class="center-toast-mask {{centerToastClosing ? 'closing' : ''}}" wx:if="{{centerToast.show}}" catchtouchmove="noop" catchtap="noop">
  <view class="center-toast-box" catchtouchmove="noop" catchtap="noop">
    <view class="ct-icon">!</view> 
    <view class="ct-text">{{centerToast.text}}</view>
  </view>
</view>

<!-- ================= 10. 智能粘贴输入弹窗 ================= -->
<view class="smart-paste-mask {{smartPasteClosing ? 'closing' : ''}}" wx:if="{{showSmartPasteModal}}" style="z-index: 99999;" catchtouchmove="noop" catchtap="noop">
  <view class="smart-paste-box" catchtouchmove="noop" catchtap="noop">
    <view class="sp-title">智能粘贴</view>
    <view class="sp-desc">请将姓名、电话、地址粘贴到下方框中</view>
    <textarea 
      class="sp-textarea" 
      placeholder="例如：张三 13800138000 广东省深圳市南山区..." 
      value="{{smartPasteVal}}" 
      bindinput="onSmartPasteInput"
      adjust-position="{{true}}"
      fixed="{{true}}"
    ></textarea>
    <view class="sp-btn-row">
      <view class="sp-btn cancel" bindtap="closeSmartPasteModal">取消</view>
      <view class="sp-btn confirm" bindtap="confirmSmartPaste">智能分析</view>
    </view>
  </view>
</view>

<!-- ================= 自定义操作菜单（替代 wx.showActionSheet） ================= -->
<view class="action-sheet-mask {{actionSheetClosing ? 'closing' : ''}}" wx:if="{{actionSheet.show}}" bindtap="closeActionSheet" catchtouchmove="noop" catchtap="noop">
  <view class="action-sheet-box" catchtap="noop" catchtouchmove="noop">
    <view 
      class="action-sheet-item" 
      wx:for="{{actionSheet.itemList}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="onActionSheetItemTap"
    >
      {{item}}
    </view>
    <view class="action-sheet-cancel" bindtap="closeActionSheet">取消</view>
  </view>
</view>

<!-- ================= 11. 自定义全屏视频播放器 ================= -->
<view class="video-modal-mask" wx:if="{{showVideoPlayer}}" style="z-index: 99999;" bindtap="toggleVideoPlayPause" catchtouchmove="noop">
  <view class="video-close-btn" catchtap="closeVideoPlayer">✕</view>
  <video 
    src="{{currentVideoUrl}}" 
    id="fullscreen-video"
    autoplay="{{true}}" 
    preload="auto"
    class="fullscreen-video" 
    show-fullscreen-btn="{{false}}" 
    show-center-play-btn="{{false}}"
    object-fit="contain"
    bindplay="onVideoPlay"
    bindpause="onVideoPause"
    bindcanplay="onVideoCanPlay"
    bindtimeupdate="onVideoTimeUpdate"
    bindtap="toggleVideoPlayPause"
  ></video>
  <view class="video-pause-overlay {{!isVideoPlaying ? 'show' : ''}}" catchtap="toggleVideoPlayPause">
    <view class="play-icon">
      <view class="play-triangle"></view>
    </view>
  </view>
</view>

<!-- ================= 自定义加载动画（白色背景进度条） ================= -->
<view class="loading-mask" wx:if="{{showLoadingAnimation}}" catchtouchmove="noop" catchtap="noop">
  <view class="loader" catchtouchmove="noop" catchtap="noop">
    <text class="loader-label">{{loadingText}}</text>
    <view class="loading-bar"></view>
  </view>
</view>

</view>
<!-- 全局自定义弹窗组件 -->
<custom-toast id="custom-toast" />
