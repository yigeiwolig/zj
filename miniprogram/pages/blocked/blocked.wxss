/* miniprogram/pages/blocked/blocked.wxss */
page {
  background-color: #ffffff;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #1d1d1f;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0 60rpx;
  box-sizing: border-box;
  position: relative;
}

.center-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 100rpx; /* 视觉重心上移 */
}

/* --- 图标区 --- */
.icon-container {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 80rpx;
}

/* 旋转圆环 */
.spinner-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 6rpx solid #f2f2f7; /* 浅灰底 */
  border-top: 6rpx solid #ff3b30; /* 红色旋转条，代表错误 */
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-sizing: border-box;
}

/* 感叹号图标 */
.error-icon {
  font-size: 80rpx;
  font-weight: 800;
  color: #ff3b30; /* 红色 */
  font-family: 'SF Pro Rounded', system-ui, -apple-system, sans-serif;
  position: relative;
  z-index: 2;
  /* 微调位置 */
  padding-bottom: 10rpx; 
}

/* --- 文字区 --- */
.text-area {
  text-align: center;
  animation: fadeInUp 0.6s ease-out;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.subtitle {
  font-size: 24rpx;
  font-weight: 600;
  color: #86868b;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 40rpx;
}

.error-desc {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.error-desc text {
  font-size: 28rpx;
  color: #424245;
  line-height: 1.5;
}

/* --- 底部区 --- */
.footer {
  padding-bottom: calc(env(safe-area-inset-bottom) + 60rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeIn 1s 0.3s ease-out forwards;
  opacity: 0;
}

.action-btn {
  background: #1d1d1f !important; /* 黑色按钮 */
  color: #ffffff !important;
  font-size: 30rpx;
  font-weight: 600;
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx; /* 确保与高度一致 */
  border-radius: 48rpx; /* 长椭圆圆角 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
  transition: transform 0.1s;
  /* 强制居中 */
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}

.btn-hover {
  transform: scale(0.98);
  background: #333 !important;
}

.debug-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.debug-info text {
  font-size: 20rpx;
  color: #a1a1a6;
  font-family: 'SF Mono', monospace; /* 等宽字体，像代码 */
  letter-spacing: 0.5rpx;
  }

/* 动画 */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  to { opacity: 1; }
}

/* --- 弹窗样式 (重构版) --- */
/* 🔴 优化后的弹窗样式 - 参考 index 页面 */
.custom-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7); /* 深色遮罩 */
  backdrop-filter: blur(10px); /* 毛玻璃效果 */
  z-index: 1000000001 !important; /* 🔴 修复：页面级弹窗应该高于组件级，和 my 页面一致 */
  display: flex;
  align-items: center;
  justify-content: center;
  
  /* 遮罩淡入淡出 */
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.custom-modal-mask.active {
  opacity: 1;
  pointer-events: auto;
}

.custom-modal-mask.closing {
  opacity: 0;
}

.custom-modal-box {
  width: 600rpx; /* 统一宽度，和 shop 页面一样 */
  background: #ffffff;
  border-radius: 50rpx; /* 统一圆角，和 shop 页面一样 */
  padding: 70rpx 50rpx; /* 统一内边距，和 shop 页面一样 */
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15); /* 统一阴影，和 shop 页面一样 */
  animation: cartBoxPopIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; /* 统一动画名称 */
}

.custom-modal-mask {
  background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(5px); /* 统一背景色，和 shop 页面一样 */
  animation: cartMaskFadeIn 0.25s ease-out forwards; /* 统一动画名称 */
}
.custom-modal-mask.active {
  opacity: 1;
  pointer-events: auto;
}
.custom-modal-mask.closing {
  animation: cartMaskFadeOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; /* 统一动画名称 */
}
.custom-modal-mask.closing .custom-modal-box {
  animation: cartBoxShrinkOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; /* 统一动画名称 */
}

@keyframes cartMaskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes cartMaskFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
@keyframes cartBoxPopIn {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes cartBoxShrinkOut {
  0% {
    transform: scale(1) translateY(0);
    opacity: 1;
    filter: blur(0);
  }
  100% {
    transform: scale(0.6) translateY(-60rpx);
  opacity: 0;
    filter: blur(12rpx);
  }
}

/* ================= 统一的"内容已复制"弹窗（样式和首页一致） ================= */
.copy-success-modal {
  width: 400rpx !important;
  padding: 60rpx 40rpx !important;
  min-height: auto;
}

.copy-success-modal .modal-icon-new {
  display: flex !important; /* 显示勾勾图标 */
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: #000;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  animation: checkmarkPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.copy-success-modal .modal-title-new {
  font-size: 36rpx !important;
  margin-bottom: 0 !important;
  letter-spacing: 0 !important;
  font-weight: 600 !important;
  animation: toastTextPop 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

.copy-success-modal .modal-content-new {
  margin-bottom: 0 !important;
  display: none !important;
}

/* 旧样式保留（如果其他地方用到） */
.check-icon {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.check-line {
  position: absolute;
  background-color: #1d1d1f;
  border-radius: 4rpx;
  opacity: 0;
}

.custom-modal-mask.active .check-line {
  opacity: 1;
}

/* 短线 */
.line-tip {
  width: 24rpx;
  height: 8rpx;
  left: 14rpx;
  top: 46rpx;
  transform: rotate(45deg);
  transform-origin: left center;
  animation: checkTip 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.1s forwards;
}

/* 长线 */
.line-long {
  width: 48rpx;
  height: 8rpx;
  left: 28rpx;
  top: 62rpx;
  transform: rotate(-45deg);
  transform-origin: left center;
  animation: checkLong 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.2s forwards;
}

@keyframes checkTip {
  from { width: 0; opacity: 0; }
  to { width: 24rpx; opacity: 1; }
}

@keyframes checkLong {
  from { width: 0; opacity: 0; }
  to { width: 48rpx; opacity: 1; }
}

.modal-title-new {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

/* 🔴 验证通过弹窗特化样式 - 白底黑字，简洁大气，统一和内容已复制一样 */
.success-modal {
  background: #FFFFFF !important;
  width: 400rpx !important; /* 统一宽度，和内容已复制一样 */
  padding: 60rpx 40rpx !important; /* 统一内边距 */
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2) !important; /* 减轻阴影 */
}

.success-modal .modal-icon-new.success-icon {
  display: flex !important; /* 显示勾勾图标 */
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: #000;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  animation: checkmarkPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes checkmarkPop {
  from {
    transform: scale(0) rotate(-180deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.success-modal .modal-title-new {
  font-size: 36rpx !important; /* 统一标题字体大小，和内容已复制一样 */
  margin-bottom: 0 !important;
  letter-spacing: 0 !important;
  font-weight: 600 !important;
  color: #000000;
  animation: toastTextPop 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

@keyframes fadeInUp {
  0% {
    transform: translateY(20rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

/* A方案：纯文字轻微弹一下（和 custom-toast 保持一致） */
@keyframes toastTextPop {
  0%   { transform: translateY(6rpx); opacity: 0.2; }
  65%  { transform: translateY(-2rpx); opacity: 1; }
  100% { transform: translateY(0); opacity: 1; }
}